{
  "name": "communication-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Acumon Communications — multi-tenant SaaS for governed firm-wide communications",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "tsx scripts/migrate-history-backfill.ts && prisma migrate deploy && tsx prisma/post-migrate.ts && tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "check:tenant-scoping": "tsx scripts/check-tenant-scoping.ts",
    "check:migration-prefixes": "tsx scripts/check-migration-prefixes.ts",
    "rotate-encryption-keys": "tsx scripts/rotate-encryption-keys.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:setup-db": "tsx tests/setup-db.ts",
    "eval": "tsx evals/cli.ts",
    "eval:all": "tsx evals/cli.ts all",
    "eval:judge": "tsx evals/cli.ts judge",
    "eval:draft": "tsx evals/cli.ts draft",
    "eval:adherence": "tsx evals/cli.ts adherence",
    "eval:sentiment": "tsx evals/cli.ts sentiment",
    "eval:opportunity": "tsx evals/cli.ts opportunity",
    "eval:fcg": "tsx evals/cli.ts fcg",
    "eval:ucg": "tsx evals/cli.ts ucg",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.2.1",
    "imapflow": "^1.3.3",
    "next": "^15.1.4",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^7.0.7",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^7.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
