enum AuditEventType {
  TENANT_PROVISIONED
  USER_INVITED
  USER_JOINED
  USER_LEFT
  MEMBERSHIP_CHANGED
  CHANNEL_AUTHORISED
  CHANNEL_REVOKED
  FCG_DRAFT_CREATED
  FCG_PROPOSED
  FCG_VOTE_CAST
  FCG_COMMITTED
  FCG_PROPOSAL_FAILED
  FCG_PROPOSAL_EXPIRED
  UCG_DRAFTED
  UCG_JUDGED
  UCG_COMMITTED
  UCG_AMENDED
  COMPLIANCE_RULING
  COMPLIANCE_OVERRIDE
  UCG_CONFLICT_FLAGGED
  UCG_RULE_AUTO_SUSPENDED
  DRAFT_PRODUCED
  DRAFT_EDITED
  DRAFT_REGENERATED
  DRAFT_SENT_MARKED
  ACTION_CREATED
  ACTION_COMPLETED
  ACTION_DISMISSED
  ACTION_REOPENED
  ADHERENCE_SCORED
  SENTIMENT_CLASSIFIED
  SENTIMENT_ESCALATED
  SENTIMENT_ACKNOWLEDGED
  DPIA_ATTESTED
  DSAR_OPENED
  DSAR_FULFILLED
  AUDIT_EXPORTED
  MEETING_CREATED
  MEETING_PAPER_DRAFTED
  MEETING_PAPER_REGENERATED
  MEETING_PAPER_EDITED
  MEETING_PAPER_ISSUED
  SALES_IDENTIFIER_ENABLED
  SALES_IDENTIFIER_DISABLED
  SI_LAWFUL_BASIS_ATTESTED
  OPPORTUNITY_DETECTED
  OPPORTUNITY_ACCEPTED
  OPPORTUNITY_REVISED
  OPPORTUNITY_REJECTED
  OPPORTUNITY_ROUTED_TO_PARTNER
  OPPORTUNITY_COMMENTED
  USER_ACCESS_REVOKED
  USER_REAUTHORISED
  USER_MARKED_LEAVER
  USER_LEAVER_REVERSED
  MEMBERSHIP_SUSPENDED_AFTER_GRACE
  MEMBERSHIP_ANONYMISED
  /// Post-PRD hardening — GDPR Art. 17 fulfillment. The User row is
  /// pseudonymised (email → `erased-<id>@erased.invalid`, name/image
  /// nulled), every Membership of this user across every tenant flips to
  /// ANONYMISED, sessions revoked, TOTP wiped, OAuth tokens deleted. The
  /// audit event lands on every affected tenant's chain so each Firm
  /// Administrator sees the action against their own data.
  USER_ERASED
  /// Post-PRD hardening — a FIRM_ADMIN exported the compliance evidence
  /// pack (security posture snapshot for SOC 2 / ISO 27001 / vendor
  /// audits). Payload carries `{ exportedSections: string[] }`.
  COMPLIANCE_EVIDENCE_PACK_EXPORTED
  /// Post-PRD hardening — operator clicked "Send test event" on a
  /// webhook subscription. Synthesises a single WebhookDelivery for
  /// the target subscription with a sentinel payload, lets the
  /// existing delivery worker fire it through the full signing +
  /// retry pipeline. Excluded from `WEBHOOK_SELF_EVENT_TYPES` fan-out
  /// — writing this audit row must NOT enqueue it for every matching
  /// subscription.
  WEBHOOK_SUBSCRIPTION_TESTED
  UCG_FROZEN
  UCG_ANONYMISED
  BILLING_PLAN_UPDATED
  BILLING_PERIOD_CLOSED
  BILLING_PERIOD_REOPENED
  ROADMAP_PHASE_UPDATED
  ROADMAP_EXIT_CRITERION_MET
  ROADMAP_EXIT_CRITERION_UNMET
  RISK_UPDATED
  RISK_REVIEWED
  SIGNOFF_QUESTION_UPDATED
  SIGNOFF_QUESTION_DECIDED
  SIGNOFF_QUESTION_REOPENED
  MEETING_NOTE_TAKING_DISCLOSED
  MEETING_NOTE_TAKING_OPTED_OUT
  MEETING_NOTE_TAKING_BLOCKED
  MEETING_TRANSCRIPT_INGESTED
  MEETING_SUMMARY_DRAFTED
  MEETING_SUMMARY_APPROVED
  MEETING_MINUTES_DRAFTED
  MEETING_MINUTES_APPROVED
  MEETING_MINUTES_CIRCULATED
  XCL_OPT_IN
  XCL_OPT_OUT
  XCL_CANDIDATE_PROPOSED
  XCL_CANDIDATE_APPROVED
  XCL_CANDIDATE_REJECTED
  XCL_CANDIDATE_COMMITTED
  XCL_REID_TEST_RECORDED
  SANDBOX_PROVISIONED
  SANDBOX_MEMBER_ADDED
  SANDBOX_FCG_PROMOTED
  SANDBOX_OUTCOME_RECORDED
  TENANT_TERMINATION_NOTICED
  TENANT_TERMINATION_REVERSED
  TENANT_TERMINATION_EXPORT_GENERATED
  TENANT_HARD_DELETED
  SUBPROCESSOR_ADDED
  SUBPROCESSOR_UPDATED
  SUBPROCESSOR_REMOVED
  SUBPROCESSOR_REINSTATED
  TERMS_RECORDED
  TERMS_ACTIVATED
  TERMS_SUPERSEDED
  TERMS_AMENDED
  FCG_SCAN_INITIATED
  FCG_SCAN_COMPLETED
  FCG_SCAN_FAILED
  FCG_SCAN_PROMOTED
  FCG_SCAN_DISCARDED
  INTEGRATION_TARGET_ADDED
  INTEGRATION_TARGET_UPDATED
  INTEGRATION_TARGET_STATUS_CHANGED
  PROCESSING_ACTIVITY_ADDED
  PROCESSING_ACTIVITY_UPDATED
  PROCESSING_ACTIVITY_REMOVED
  TIA_RECORDED
  TIA_REVOKED
  TIA_EXPIRED
  BREACH_DETECTED
  BREACH_TRIAGED
  BREACH_CONTAINED
  BREACH_RESOLVED
  BREACH_CLIENT_NOTIFIED
  BREACH_UPDATE_PUBLISHED
  SLA_TARGET_UPDATED
  SLA_MEASUREMENT_RECORDED
  LANGUAGE_ADDED
  LANGUAGE_UPDATED
  ACCESSIBILITY_STATEMENT_PUBLISHED
  ONBOARDING_STEP_TICKED
  ONBOARDING_STEP_UNTICKED
  ONBOARDING_PHASE_CHANGED
  ONBOARDING_COMPLETED
  DRAFT_SYNTHESISED_FROM_OUTBOX
  ADHERENCE_ESCALATED
  ADHERENCE_ACKNOWLEDGED
  CHANNEL_TOKEN_REFRESHED
  CHANNEL_TOKEN_REFRESH_FAILED
  NOTIFICATION_DISPATCHED
  NOTIFICATION_DISPATCH_FAILED
  NOTIFICATION_DIGEST_RUN
  /// Post-PRD hardening item 45 — a User toggled email delivery for an
  /// opt-outable notification kind on /<slug>/account. Payload carries
  /// `{ kind, emailEnabled, prior }`. Mandatory kinds (breach,
  /// audit-chain, subprocessor-*, cron-stalled, escalations, totp-reset)
  /// cannot be toggled — those throws `ValidationError` and never reach
  /// this event.
  NOTIFICATION_PREFERENCE_CHANGED
  RATE_LIMIT_EXCEEDED
  TOTP_ENROLLED
  TOTP_DISABLED
  TOTP_VERIFIED
  TOTP_VERIFICATION_FAILED
  TOTP_RECOVERY_CODE_USED
  /// Post-PRD hardening item 48 — the User regenerated their TOTP
  /// recovery code set without disabling 2FA (requires a current TOTP
  /// code as proof of device possession). Payload carries `{ count,
  /// priorRemaining }` but no plaintext / hashes.
  TOTP_RECOVERY_CODES_REGENERATED
  /// Post-PRD hardening item 51 — an operator triggered the
  /// auto-draft backfill on historic ingested inbound. Payload
  /// carries `{ daysBack, produced, skipped, errored,
  /// tenantsScanned }`. Distinct from `DRAFT_PRODUCED` (which
  /// records each individual auto-produced draft) — this records the
  /// human-initiated batch, so a reviewer can ask "who pressed the
  /// button, when, and what window did they choose."
  AUTO_DRAFT_BACKFILL_TRIGGERED
  /// Post-PRD hardening item 53 — a daily cron found a `ChannelAuth`
  /// whose `expiresAt` falls inside a warning threshold (7-day or
  /// 1-day) and dispatched a notification to the owning Membership.
  /// Payload carries `{ channelAuthId, channelId, channelKind,
  /// threshold: "7d" | "1d", expiresAt, daysUntilExpiry }`. Dedupes
  /// via the dispatch table's (membership, kind, dedupeKey) uniqueness
  /// — one row per (channelAuth, threshold), so a 7-day warning fires
  /// once even though the cron runs daily.
  CHANNEL_AUTH_EXPIRY_WARNED
  TENANT_TOTP_REQUIREMENT_CHANGED
  SESSION_REVOKED
  SESSION_REVOKED_BY_ADMIN
  SESSION_REVOKED_ALL
  WEBHOOK_SUBSCRIPTION_CREATED
  WEBHOOK_SUBSCRIPTION_UPDATED
  WEBHOOK_SUBSCRIPTION_DELETED
  WEBHOOK_SUBSCRIPTION_AUTO_DISABLED
  /// Post-PRD hardening item 46 — operator rotated the signing secret on
  /// a WebhookSubscription. Payload carries `{ graceWindowHours,
  /// prevRetiresAt }`. The plaintext secret is never recorded.
  WEBHOOK_SUBSCRIPTION_SECRET_ROTATED
  WEBHOOK_DELIVERED
  WEBHOOK_DELIVERY_FAILED
  WEBHOOK_DEAD_LETTERED
  WEBHOOK_REPLAYED
  TENANT_SESSION_TIMEOUT_CHANGED
  API_KEY_CREATED
  API_KEY_REVOKED
  API_KEY_AUTH_FAILED
  API_KEY_AUTO_REVOKED
  API_KEY_USED
  TENANT_IP_ALLOWLIST_CHANGED
  IP_ALLOWLIST_DENIED
  STEP_UP_VERIFIED
  TOTP_RESET_BY_ADMIN
  SIGN_IN_NEW_DEVICE
  CRON_RUN_FAILED
  /// Post-PRD hardening item 47 — a cron invocation found another run
  /// already in flight (advisory lock held) and exited without doing
  /// any work. Payload carries `{ cronName }`. The scheduler's response
  /// also surfaces `skipped: "concurrent"` so observability dashboards
  /// can distinguish "skipped" from "succeeded with no work to do".
  CRON_RUN_SKIPPED_CONCURRENT
  CRON_STALLED
  AUDIT_CHAIN_VERIFIED
  AUDIT_CHAIN_TAMPERED
  SUBPROCESSOR_CHANGE_ANNOUNCED
  SUBPROCESSOR_CHANGE_CANCELLED
  SUBPROCESSOR_CHANGE_EFFECTIVE
  SUBPROCESSOR_OBJECTION_RAISED
  SUBPROCESSOR_OBJECTION_WITHDRAWN
  ENCRYPTION_KEYS_ROTATED
}

enum BillingPeriodStatus {
  DRAFT
  CLOSED
}

enum MeetingPaperStatus {
  NONE
  DRAFTED
  EDITED
  ISSUED
}

/// PRD §7.5 — post-meeting record, either a Summary or Formal Minutes. Kind
/// is fixed at row creation; status moves DRAFTED → EDITED → APPROVED →
/// CIRCULATED. Summaries don't strictly need to circulate but the column is
/// shared so the lifecycle is uniform.
enum MeetingRecordKind {
  SUMMARY
  MINUTES
}

enum MeetingRecordStatus {
  DRAFTED
  EDITED
  APPROVED
  CIRCULATED
}

/// PRD §7.5 — provenance of an ingested meeting transcript. MANUAL is the
/// paste-into-the-form path until the platform integrations (Tier 2 in §10.2)
/// are wired up to ingest automatically.
enum TranscriptSource {
  TEAMS
  ZOOM
  MEET
  MANUAL
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  /// Present and being actively mitigated.
  ACTIVE
  /// Controls in place and judged effective; still tracked.
  MITIGATED
  /// Tolerated within the firm's risk appetite — controls light-touch by choice.
  ACCEPTED
  /// No longer applicable — superseded, scope changed, or the threat model moved on.
  CLOSED
}

enum RoadmapPhaseStatus {
  PLANNED
  ACTIVE
  COMPLETE
}

enum SignOffStatus {
  /// Awaiting decision; the working PRD assumption stands provisionally.
  OPEN
  /// An explicit decision has been recorded — `decision` carries the text.
  DECIDED
  /// Consciously punted out of the current sign-off window.
  DEFERRED
}

/// PRD §14.2 Sandbox lifecycle. PENDING is the default for an open sandbox;
/// the three terminal outcomes match the PRD ("promote the candidate FCG to
/// production, iterate, or decline and exit"). ITERATING is also terminal in
/// the sense that it concludes the *current* sandbox window — the Client
/// then opens a new window if they want to keep iterating.
enum SandboxOutcome {
  PENDING
  PROMOTED
  ITERATING
  DECLINED
}

/// PRD §11 Cross-Client Learning. Categories of insight the curator pipeline
/// can promote into global defaults.
enum XclInsightKind {
  /// An FCG rule change (add/modify/remove) that improved adherence in source tenant.
  FCG_AMENDMENT
  /// A Sales Identifier classification rule learned from reviewer accept/revise/reject.
  OPPORTUNITY_RULE
  /// A refinement to the compliance judge prompt or rubric.
  JUDGE_PROMPT
}

/// PRD §11 candidate lifecycle:
///   PENDING   — auto-redacted, waiting for human curator (PRD §11.3).
///   APPROVED  — curator approved; queued for the next global-defaults commit.
///   REJECTED  — curator rejected; rejection rate + rationale tracked per §11.3.
///   COMMITTED — rolled into the global model defaults (PRD §11.4).
enum XclCandidateStatus {
  PENDING
  APPROVED
  REJECTED
  COMMITTED
}

/// PRD §15.4 — categories of Client-Acumon terms.
/// The Sub-Processor List is published per §15.3 as a global table (not a
/// per-Client document) and is therefore intentionally absent here.
enum TermsKind {
  MSA
  DPA
  AUP
  SLA
}

/// PRD §15.4 lifecycle. ACTIVE = currently in force. SUPERSEDED rows are
/// retained — "persistent until changed" — and survive non-renewal for
/// audit + DSAR per §12.5.
enum TermsStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

/// PRD §10 integration tier. Tier 1 must be live at GA; Tier 2 within 6
/// months of GA; Tier 3 is roadmap; SDK is the generic Integration Capability
/// (§10.4) — Clients and partners wire arbitrary systems via the documented
/// SDK + MCP adaptor layer rather than bespoke engineering.
enum IntegrationTier {
  TIER_1
  TIER_2
  TIER_3
  SDK
}

/// PRD §10 integration delivery status. PLANNED = on the roadmap, no code
/// shipped; IN_DEVELOPMENT = actively under build; AVAILABLE = generally
/// available to Clients; DEPRECATED = sunset (kept readable for audit so
/// past Channel rows still resolve their target).
enum IntegrationStatus {
  PLANNED
  IN_DEVELOPMENT
  AVAILABLE
  DEPRECATED
}

/// PRD §10 integration category — drives the Channel.kind that the target
/// produces and how it appears in the integrations catalogue. Multiple
/// targets can share a category (e.g. Microsoft 365 and Google Workspace
/// both produce EMAIL channels).
enum IntegrationCategory {
  EMAIL
  CHAT
  DOCUMENTS
  CALENDAR
  MEETINGS
  E_SIGNATURE
  PRACTICE_MANAGEMENT
  CRM
  KNOWLEDGE_BASE
  ACCOUNTING
  TASK_MANAGEMENT
  OTHER
}

/// PRD §14.1 onboarding phase. Mirrors the six PRD stages plus a terminal
/// LIVE state once production rollout is complete. Phases progress in
/// strict order; reverting is allowed (e.g. Pilot → Configuration when an
/// FCG amendment is needed) but completing requires every prior phase to
/// have at least one ticked item.
enum OnboardingPhase {
  COMMERCIAL
  TECHNICAL
  COMPLIANCE
  CONFIGURATION
  PILOT
  PRODUCTION
  LIVE
}

/// PRD §13.1 Service Level kind. AVAILABILITY = uptime percentage;
/// LATENCY = response-time threshold (median or P95). The unit lives on
/// the row because availability is a percentage and latency is seconds.
enum SlaKind {
  AVAILABILITY
  LATENCY
}

/// PRD §13.1 measurement outcome. MET = measured value at or better than
/// the target; MISSED = worse; INSUFFICIENT_DATA = the period did not
/// produce enough samples to make a determination (e.g. a tenant with no
/// drafts produced no latency samples in the month).
enum SlaOutcome {
  MET
  MISSED
  INSUFFICIENT_DATA
}

/// PRD §12.9 Breach incident lifecycle. TRIAGE = operator confirming
/// scope and impact; INVESTIGATING = root-cause work in progress; CONTAINED
/// = exposure stopped, residual cleanup; RESOLVED = closed with full
/// post-incident review. The 24-hour notice clock is keyed off
/// `BreachIncident.awareAt`, not `detectedAt` — under UK GDPR the duty is
/// triggered by Acumon's awareness, not the moment the incident technically
/// began.
enum BreachStatus {
  TRIAGE
  INVESTIGATING
  CONTAINED
  RESOLVED
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// PRD §12.9 client-notification lifecycle. PENDING = generated, awaiting
/// operator dispatch; NOTIFIED = sent to the Client (within 24h SLA);
/// ACKNOWLEDGED = the Client has acknowledged receipt; SUPERSEDED = an
/// updated notification has been issued for the same incident.
enum BreachNotificationStatus {
  PENDING
  NOTIFIED
  ACKNOWLEDGED
  SUPERSEDED
}

/// PRD §12.6 Transfer Impact Assessment lifecycle. RECORDED = the Client
/// has signed SCCs + a documented TIA for the third-country sub-processor;
/// EXPIRED = the period covered has passed (TIAs are reviewed annually);
/// REVOKED = the Client withdrew authorisation (e.g. closed the channel
/// that depended on the sub-processor).
enum TIAStatus {
  RECORDED
  EXPIRED
  REVOKED
}

/// PRD §5.1.1 Firm Culture Scan lifecycle. PENDING = scan record created;
/// ANALYSING = corpus pulled, model running; DRAFTED = proposal staged for
/// FCT review; PROMOTED = the proposal opened for vote (or already committed);
/// ERRORED = scan failed (errorMessage holds the reason); DISCARDED =
/// operator decided not to use the scan output.
enum FirmCultureScanStatus {
  PENDING
  ANALYSING
  DRAFTED
  PROMOTED
  ERRORED
  DISCARDED
}

// ─── NextAuth ──────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id             String    @id @default(cuid())
  sessionToken   String    @unique
  userId         String
  expires        DateTime
  /// Post-PRD hardening item 12. Timestamp at which this session passed a
  /// TOTP step-up challenge. Null = not yet verified for this session. The
  /// layout-level gate redirects to /login/2fa when the User has a verified
  /// UserTotp but the active Session has no totpVerifiedAt. Reset on every
  /// new session (sign-in produces a fresh Session row).
  totpVerifiedAt DateTime?
  /// Post-PRD hardening item 13 — session management. Metadata captured the
  /// first time the layout observes this session (no good hook in the
  /// PrismaAdapter createSession path, so we lazy-populate). Used by the
  /// /account session list + admin tenant view for incident response.
  createdAt      DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  userAgent      String?
  ipAddress      String?
  /// When set, the wrapped PrismaAdapter treats this session as signed out
  /// and the cookie is invalid. Row is preserved for forensic history.
  revokedAt      DateTime?
  revokedById    String?
  revokedReason  String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core ──────────────────────────────────────────────────────────────────

model Tenant {
  id                                   String          @id @default(cuid())
  slug                                 String          @unique
  name                                 String
  jurisdiction                         Jurisdiction    @default(UK)
  status                               TenantStatus    @default(ACTIVE)
  isSandbox                            Boolean         @default(false)
  parentTenantId                       String?
  parentTenant                         Tenant?         @relation("SandboxOf", fields: [parentTenantId], references: [id])
  sandboxes                            Tenant[]        @relation("SandboxOf")
  /// PRD §14.2 sandbox lifecycle. Only meaningful when `isSandbox = true`.
  /// The window is provisioned for `sandboxCohortLimit` users (default 10)
  /// over `sandboxClosesAt - sandboxOpenedAt` days (default 30). On
  /// conclusion the operator records the outcome (PROMOTED / ITERATING /
  /// DECLINED) and, when promoted, the FCG that was lifted into the parent.
  sandboxOpenedAt                      DateTime?
  sandboxClosesAt                      DateTime?
  sandboxCohortLimit                   Int             @default(10)
  sandboxOutcome                       SandboxOutcome  @default(PENDING)
  sandboxOutcomeAt                     DateTime?
  sandboxOutcomeByName                 String?
  sandboxOutcomeNotes                  String?         @db.Text
  /// FCG (in this sandbox tenant) chosen as the candidate for promotion.
  sandboxPromotedFcgId                 String?
  /// FCGProposal id created on the parent tenant when promoting — the
  /// candidate is staged via the parent's normal §6 governance, not
  /// committed silently.
  sandboxPromotedProposalId            String?
  retentionDays                        Int             @default(2555)
  quorumPct                            Int             @default(50) // simple majority of total membership
  votingWindowDays                     Int             @default(5)
  // Sales Identifier (PRD §8) — opt-in add-on. Enabling is a DPIA-relevant
  // scope change and is gated on a separate lawful-basis attestation by the
  // Firm Administrator (PRD §8.5: mining counterparty correspondence to
  // identify revenue is a separate processing purpose). The detector and
  // the reviewer console refuse to run unless `salesIdentifierEnabled`
  // is true and the lawful-basis acknowledgement is on file.
  salesIdentifierEnabled               Boolean         @default(false)
  salesIdentifierEnabledAt             DateTime?
  salesIdentifierLawfulBasisAttestedAt DateTime?
  salesIdentifierLawfulBasisAttestedBy String?
  salesIdentifierLawfulBasisNote       String?         @db.Text
  // PRD §15.1 pricing structure. Currency + base licence per active User per
  // month, plus the Sales Identifier add-on (with the Acumon-default-Partner
  // discount and the Cross-Client Learning opt-in discount stacking on top),
  // plus the flat per-tenant Customer-Managed-Keys uplift. Sandbox tenants
  // get the first 30 days free per §15.1; `sandboxBillingFreeUntil` snapshots
  // that window so it remains stable if the tenant exits sandbox mid-month.
  // All money is stored in minor units (e.g. pence) to avoid floating point.
  pricingCurrency                      String          @default("GBP")
  pricingBaseMinor                     Int             @default(5000)
  pricingSalesIdMinor                  Int             @default(2000)
  pricingSalesIdPartnerDefault         Boolean         @default(true)
  pricingSalesIdPartnerDiscountPct     Int             @default(25)
  pricingCrossClientLearningOptIn      Boolean         @default(false)
  pricingCclDiscountPct                Int             @default(10)
  /// PRD §11.2 Cross-Client Learning (XCL) attestation. Opt-in is a separate
  /// addendum to the Order Form — record who signed, when, and a reference to
  /// the document. The boolean above (`pricingCrossClientLearningOptIn`)
  /// drives both the lawful-basis gate AND the per-§15.1 billing discount;
  /// these fields capture the attestation that authorises the gate. Opt-out
  /// is recorded separately so the audit trail keeps the change history.
  crossClientLearningOptedInAt         DateTime?
  crossClientLearningOptedInByName     String?
  crossClientLearningAddendumRef       String?
  crossClientLearningOptedOutAt        DateTime?
  crossClientLearningOptedOutReason    String?         @db.Text
  pricingCmkEnabled                    Boolean         @default(false)
  pricingCmkMinor                      Int             @default(50000)
  sandboxBillingFreeUntil              DateTime?
  /// PRD §14.4 termination lifecycle. `terminationNoticeAt` is when the
  /// Client (or Acumon, on Client request) noticed termination; status
  /// transitions ACTIVE → TERMINATING. `terminationEffectiveAt` is the
  /// hard-delete cut-off (default = noticeAt + 90d per PRD). `terminationCompletedAt`
  /// is the moment the cron sweep actually ran the deletion and moved status
  /// to TERMINATED. The notice can be reversed any time before completion.
  terminationNoticeAt                  DateTime?
  terminationByName                    String?
  terminationReason                    String?         @db.Text
  terminationEffectiveAt               DateTime?
  terminationCompletedAt               DateTime?
  /// Reference to the most recent export package generated for the wind-down.
  /// One per tenant; regenerating overwrites.
  terminationExportPackageId           String?
  /// Statutory retention floor — audit logs and DPIA attestations remain
  /// readable until this date even after `terminationCompletedAt`. Null
  /// means "use the default §12.5 schedule" applied at delete time.
  terminationStatutoryRetentionUntil   DateTime?
  /// PRD §14.1 onboarding lifecycle. `onboardingPhase` advances through
  /// COMMERCIAL → TECHNICAL → COMPLIANCE → CONFIGURATION → PILOT →
  /// PRODUCTION → LIVE. The page derives sub-step status from existing
  /// data (DPIA attestations, FCG commit, sandbox provisioning, etc.) and
  /// records manual ticks in `OnboardingChecklistItem` for items the
  /// platform cannot detect (commercial signoff, SSO configuration, etc.).
  onboardingPhase                      OnboardingPhase @default(COMMERCIAL)
  onboardingStartedAt                  DateTime?
  onboardingCompletedAt                DateTime?
  /// Free-form per-tenant notes on the rollout — pinned commentary, links
  /// to the onboarding plan, etc.
  onboardingNotes                      String?         @db.Text
  /// PRD §13.5 + backlog item 10. Locale (BCP-47) used by any Membership
  /// in this tenant that has no explicit preference of its own. New tenants
  /// default to en-GB so existing behaviour is preserved. Free-form text
  /// rather than an FK to SupportedLanguage so renaming a row doesn't break
  /// existing tenant preferences; the i18n loader silently falls back to
  /// en-GB on any unknown code.
  defaultLocale                        String          @default("en-GB")
  /// Post-PRD hardening item 12. When true, every active Membership in this
  /// tenant must have a verified `UserTotp` before reaching tenant routes;
  /// the layout redirects un-enrolled users to /account to enroll. Per-User
  /// enrollment is always self-service via /account regardless of this flag —
  /// the flag governs whether enrollment is *required*, not whether it is
  /// *permitted*.
  requireTotp                          Boolean         @default(false)
  /// Post-PRD hardening item 15 — session idle/absolute timeouts. Null on
  /// either column means "inherit the platform default" (60 minutes idle,
  /// 1440 minutes / 24h absolute). When a User has memberships across
  /// multiple tenants, the STRICTEST tenant's threshold wins for each
  /// dimension — sessions are per-User globally so the conservative choice
  /// is to take the smallest non-null configured value.
  sessionIdleTimeoutMinutes            Int?
  sessionAbsoluteTimeoutMinutes        Int?
  /// Post-PRD hardening item 17 — tenant-wide IP allowlist. Empty array
  /// (the default) means "no restriction"; current behaviour preserved
  /// for every tenant that hasn't configured this. Non-empty means the
  /// caller's IP must match at least one entry to authenticate. Applies
  /// to BOTH session-based access (layout-level enforcement) and
  /// API-key access (`withApiKey` wrapper).
  ///
  /// Free-form TEXT[] in Postgres; the page handler validates CIDR
  /// shape before persisting so malformed entries can't reach the
  /// runtime matcher. Both IPv4 and IPv6 are supported.
  allowedIpCidrs                       String[]        @default([])
  /// Post-PRD hardening item 18 — step-up authentication freshness
  /// window. Null = inherit platform default (5 minutes). Cross-tenant
  /// Users get the strictest non-null value across their active
  /// memberships (same pattern as session timeouts). Applies to
  /// high-blast-radius operations: IP allowlist edits, TOTP policy
  /// flips, session timeout edits, API key creation, webhook sub
  /// creation. A request whose `Session.totpVerifiedAt` is older
  /// than this window is redirected to `/auth/2fa?stepUp=1` to
  /// re-challenge before the operation proceeds.
  stepUpMaxAgeMinutes                  Int?
  createdAt                            DateTime        @default(now())
  updatedAt                            DateTime        @updatedAt

  memberships               Membership[]
  fcgs                      FirmCultureGuide[]
  fcgProposals              FCGProposal[]
  cultureScans              FirmCultureScan[]
  ucgs                      UserCultureGuide[]
  drafts                    Draft[]
  actions                   Action[]
  auditEvents               AuditEvent[]
  channels                  Channel[]
  ingestedMessages          IngestedMessage[]
  meetings                  Meeting[]
  opportunityCandidates     OpportunityCandidate[]
  sentimentSignals          SentimentSignal[]
  adherenceScores           AdherenceScore[]
  commAdherence             CommunicationAdherence[]
  dpiaAttestations          DPIAAttestation[]
  dsarRequests              DSARequest[]
  noGoSubjects              NoGoSubject[]
  billingPeriods            BillingPeriod[]
  billingUserSnapshots      BillingUserSnapshot[]
  signOffQuestions          SignOffQuestion[]
  terminationExports        TenantTerminationExport[]
  termsRecords              TermsRecord[]
  transferImpactAssessments TransferImpactAssessment[]
  breachNotifications       BreachClientNotification[]
  slaMeasurements           SlaMeasurement[]
  onboardingItems           OnboardingChecklistItem[]
  notificationDispatches    NotificationDispatch[]
  notificationInbox         NotificationInbox[]
  notificationPreferences   MembershipNotificationPreference[]
  webhookSubscriptions      WebhookSubscription[]
  webhookDeliveries         WebhookDelivery[]
  apiKeys                   ApiKey[]
  apiIdempotencyKeys        ApiIdempotencyKey[]
  auditChainVerifications   AuditChainVerification[]
  subProcessorObjections    SubProcessorObjection[]
  autoDraftSweepRuns        AutoDraftSweepRun[]

  @@index([status])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  totp        UserTotp?
}

/// Post-PRD hardening item 12. RFC 6238 TOTP enrollment for a User. Global
/// (one per User, not per Membership) — a User with memberships across
/// multiple tenants enrolls once. The secret is AES-256-GCM encrypted at
/// rest using the existing ENCRYPTION_KEY (`src/lib/channels/crypto.ts`).
/// Recovery codes are SHA-256 hashed (single-use; we only ever verify, never
/// re-display). `verifiedAt` is null between `enrollmentInitiated` and the
/// first successful code entry; until then the enrollment hasn't taken
/// effect. `disabledAt` records when the User turned 2FA off — the row is
/// kept rather than deleted so an audit trail of past enrollments survives,
/// but a disabled row is treated as no-enrollment by the gate.
model UserTotp {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secretEncrypted     String
  verifiedAt          DateTime?
  disabledAt          DateTime?
  lastUsedAt          DateTime?
  recoveryCodesHashed String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([verifiedAt])
}

model Membership {
  id                String           @id @default(cuid())
  tenantId          String
  userId            String
  role              Role             @default(USER)
  status            MembershipStatus @default(ACTIVE)
  joinedAt          DateTime         @default(now())
  leftAt            DateTime?
  perfDashOptIn     Boolean          @default(false)
  sentimentOutOptIn Boolean          @default(false)
  alternateForId    String?
  // PRD §14.3 user lifecycle. The user-revocation flow keeps Membership.status
  // = ACTIVE during the 30-day grace window so the user can still hit
  // /account to re-authorise, but `accessRevokedAt` is what the drafting gate
  // and lifecycle UI consult. `reauthDeadlineAt` = accessRevokedAt + 30d; the
  // sweep flips status → SUSPENDED and anonymises the UCG when the deadline
  // passes without re-authorisation.
  //
  // The leaver flow flips status → LEAVER_FROZEN immediately and stamps
  // `leaverMarkedAt` + `anonymiseDueAt` = +30d. The sweep flips status →
  // ANONYMISED and anonymises the UCG at the due date.
  accessRevokedAt   DateTime?
  reauthDeadlineAt  DateTime?
  leaverMarkedAt    DateTime?
  anonymiseDueAt    DateTime?
  anonymisedAt      DateTime?
  lifecycleNotes    String?          @db.Text
  // PRD §15.2 active-User definition needs "logged in within the billing
  // month". `lastLoginAt` is stamped by `getTenantContext` on every authed
  // request resolution (debounced) so the billing engine can answer that
  // question without scraping NextAuth's Session table. Distinct from
  // `User.emailVerified`, which is set once per email.
  lastLoginAt       DateTime?
  /// PRD §13.5 + backlog item 10. Per-User UI locale (BCP-47). Null means
  /// "inherit tenant.defaultLocale". Free-form text — see Tenant.defaultLocale
  /// for why we don't FK to SupportedLanguage.
  locale            String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ucgs                   UserCultureGuide[]
  cultureScansInitiated  FirmCultureScan[]                  @relation("FCGScanAuthor")
  proposalsAuthored      FCGProposal[]                      @relation("ProposalAuthor")
  votesCast              FCGVote[]                          @relation("Voter")
  votesCastAlternate     FCGVote[]                          @relation("Alternate")
  drafts                 Draft[]
  actions                Action[]
  channelAuths           ChannelAuth[]
  meetingsAsPaperAuthor  Meeting[]
  meetingsCreated        Meeting[]                          @relation("MeetingCreator")
  meetingsAsChair        Meeting[]                          @relation("MeetingChair")
  opportunitiesAssigned  OpportunityCandidate[]             @relation("OpportunityReviewer")
  opportunitiesDecided   OpportunityCandidate[]             @relation("OpportunityDecider")
  opportunityComments    OpportunityComment[]               @relation("OpportunityCommentAuthor")
  adherenceScores        AdherenceScore[]
  commAdherence          CommunicationAdherence[]
  adherenceAcknowledged  CommunicationAdherence[]           @relation("AdherenceAcknowledger")
  sentimentAssigned      SentimentSignal[]                  @relation("SentimentAssignee")
  sentimentAcknowledged  SentimentSignal[]                  @relation("SentimentAcknowledger")
  auditEventsActor       AuditEvent[]                       @relation("AuditActor")
  billingUserSnapshots   BillingUserSnapshot[]
  notificationDispatches NotificationDispatch[]
  notificationInbox      NotificationInbox[]
  notificationPrefs      MembershipNotificationPreference[]
  webhookSubscriptions   WebhookSubscription[]              @relation("WebhookSubCreatedBy")
  apiKeysCreated         ApiKey[]                           @relation("ApiKeyCreatedBy")
  apiKeysRevoked         ApiKey[]                           @relation("ApiKeyRevokedBy")
  autoDraftSweepRuns     AutoDraftSweepRun[]                @relation("AutoDraftSweepTriggeredBy")

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

// ─── Culture Guides ────────────────────────────────────────────────────────

model FirmCultureGuide {
  id             String             @id @default(cuid())
  tenantId       String
  version        Int
  status         FCGStatus          @default(DRAFT)
  language       String             @default("en-GB")
  effectiveAt    DateTime?
  supersededAt   DateTime?
  parentId       String?
  parent         FirmCultureGuide?  @relation("FCGVersionLineage", fields: [parentId], references: [id])
  children       FirmCultureGuide[] @relation("FCGVersionLineage")
  committedById  String?
  signatureBlock Json?
  createdAt      DateTime           @default(now())

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules     FCGRule[]
  ucgsBased UserCultureGuide[]

  @@unique([tenantId, version])
  @@index([tenantId, status])
}

model FCGRule {
  id               String      @id @default(cuid())
  tenantId         String
  fcgId            String
  externalId       String // stable id like "rule_xxx" used for citations
  category         FCGCategory
  channel          CommChannel @default(ANY)
  statement        String      @db.Text
  payload          Json // structured value e.g. {windowHours:24}
  rationale        String?     @db.Text
  mandatory        Boolean     @default(false)
  priority         Int         @default(100)
  evidenceRefs     Json? // array of scan references
  channelOverrides Json? // per-channel overrides

  fcg FirmCultureGuide @relation(fields: [fcgId], references: [id], onDelete: Cascade)

  @@unique([fcgId, externalId])
  @@index([tenantId, fcgId])
}

model FCGProposal {
  id             String        @id @default(cuid())
  tenantId       String
  parentFcgId    String?
  title          String
  body           String        @db.Text
  diff           Json // staged add/modify/remove operations
  proposedById   String
  isEmergency    Boolean       @default(false)
  state          ProposalState @default(DRAFTING)
  votingOpenedAt DateTime?
  votingClosesAt DateTime?
  decidedAt      DateTime?
  newFcgId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proposedBy Membership        @relation("ProposalAuthor", fields: [proposedById], references: [id])
  votes      FCGVote[]
  chatTurns  FCGChatTurn[]
  scans      FirmCultureScan[]

  @@index([tenantId, state])
}

/// PRD §5.1.1. The Firm Administrator launches a bounded scan over FCT-member
/// communications (date range + channel scope set under DPIA) and the system
/// produces a draft FCG. The scan stages an `FCGProposal` for the FCT to
/// review and open for vote — promotion remains governed by §6 quorum.
model FirmCultureScan {
  id               String                @id @default(cuid())
  tenantId         String
  initiatedById    String
  dateRangeFrom    DateTime
  dateRangeTo      DateTime
  /// JSON array of channel-kind strings in scope (e.g. ["M365","SLACK"]).
  channelKinds     Json
  status           FirmCultureScanStatus @default(PENDING)
  messagesAnalysed Int                   @default(0)
  proposalId       String?
  /// Raw analyser output: proposed rules, evidence snippets, rationale.
  analysisResult   Json?
  errorMessage     String?               @db.Text
  completedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  initiatedBy Membership   @relation("FCGScanAuthor", fields: [initiatedById], references: [id])
  proposal    FCGProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
}

model FCGChatTurn {
  id           String   @id @default(cuid())
  tenantId     String
  proposalId   String
  membershipId String?
  role         String // "user" | "assistant" | "tool"
  content      String   @db.Text
  toolCalls    Json?
  modelRunId   String?
  createdAt    DateTime @default(now())

  proposal FCGProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([tenantId, proposalId])
}

model FCGVote {
  id                 String       @id @default(cuid())
  tenantId           String
  proposalId         String
  membershipId       String
  castByMembershipId String?
  decision           VoteDecision
  comment            String?
  castAt             DateTime     @default(now())

  proposal        FCGProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voter           Membership  @relation("Voter", fields: [membershipId], references: [id])
  castByAlternate Membership? @relation("Alternate", fields: [castByMembershipId], references: [id])

  @@unique([proposalId, membershipId])
  @@index([tenantId])
}

model UserCultureGuide {
  id                      String             @id @default(cuid())
  tenantId                String
  membershipId            String
  version                 Int
  status                  UCGStatus          @default(DRAFT)
  basedOnFcgId            String
  parentId                String?
  parent                  UserCultureGuide?  @relation("UCGVersionLineage", fields: [parentId], references: [id])
  children                UserCultureGuide[] @relation("UCGVersionLineage")
  language                String             @default("en-GB")
  signatureBlock          Json?
  judgeStatus             String? // "pending" | "pass" | "fail" | "partial"
  committedAt             DateTime?
  // PRD §5.2.2 — when an FCG amendment commits, every current UCG is flagged
  // and given a 10-working-day grace period. After that, conflicting rules
  // auto-suspend. Cleared (set null + status back to COMMITTED) when the user
  // commits a new UCG version that judges clean against the new FCG.
  conflictedSinceFcgId    String?
  conflictFlaggedAt       DateTime?
  gracePeriodEndsAt       DateTime?
  conflictAutoSuspendedAt DateTime?
  // PRD §14.3 lifecycle markers. `frozenAt` is set when the owning
  // Membership transitions out of ACTIVE (revocation grace, leaver-marked).
  // While frozen the UCG is preserved (rules + signature intact) but
  // excluded from drafting. `anonymisedAt` is set by the sweep at the end
  // of the 30-day window — at that point UCGRules are dropped and
  // signatureBlock is cleared. The row itself is retained for audit.
  frozenAt                DateTime?
  anonymisedAt            DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership         @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  basedOnFcg FirmCultureGuide   @relation(fields: [basedOnFcgId], references: [id])
  rules      UCGRule[]
  rulings    ComplianceRuling[]
  chatTurns  UCGChatTurn[]

  @@unique([membershipId, version])
  @@index([tenantId, status])
}

model UCGRule {
  id               String      @id @default(cuid())
  tenantId         String
  ucgId            String
  externalId       String
  category         FCGCategory
  channel          CommChannel @default(ANY)
  statement        String      @db.Text
  payload          Json
  narrowsFcgRule   String? // FCGRule.externalId
  evidenceRefs     Json?
  channelOverrides Json?
  // Auto-suspension under PRD §5.2.2 grace-period sweep. Suspended rules
  // remain in the UCG row for audit but are excluded from drafting and
  // adherence evaluation.
  suspendedAt      DateTime?
  suspendReason    String?

  ucg UserCultureGuide @relation(fields: [ucgId], references: [id], onDelete: Cascade)

  @@unique([ucgId, externalId])
  @@index([tenantId, ucgId])
}

model UCGChatTurn {
  id         String   @id @default(cuid())
  tenantId   String
  ucgId      String
  role       String
  content    String   @db.Text
  toolCalls  Json?
  modelRunId String?
  createdAt  DateTime @default(now())

  ucg UserCultureGuide @relation(fields: [ucgId], references: [id], onDelete: Cascade)

  @@index([tenantId, ucgId])
}

model ComplianceRuling {
  id           String   @id @default(cuid())
  tenantId     String
  ucgId        String
  ucgRuleId    String?
  fcgRuleId    String?
  verdict      Verdict
  severity     String? // "blocking" | "advisory"
  explanation  String   @db.Text
  suggestedFix String?  @db.Text
  judgeModel   String
  judgeRunId   String?
  appealedById String?
  overrideById String?
  createdAt    DateTime @default(now())

  ucg UserCultureGuide @relation(fields: [ucgId], references: [id], onDelete: Cascade)

  @@index([tenantId, ucgId])
}

// ─── Drafting ──────────────────────────────────────────────────────────────

model Draft {
  id                            String           @id @default(cuid())
  tenantId                      String
  membershipId                  String
  ingestedMessageId             String?
  kind                          DraftKind        @default(EMAIL)
  status                        DraftStatus      @default(PROPOSED)
  channel                       CommChannel      @default(EMAIL)
  language                      String           @default("en-GB")
  subject                       String?
  body                          String           @db.Text
  citations                     Json?
  holdingRequired               Boolean          @default(false)
  holdingReason                 String?
  fcgWindowDeadline             DateTime?
  noGoSubjectHit                Boolean          @default(false)
  researchTaskRequired          Boolean          @default(false)
  modelRunId                    String?
  fcgVersionUsed                Int?
  ucgVersionUsed                Int?
  // Snapshot of the inbound that triggered this draft, persisted so the
  // /drafts/[id] page can offer Regenerate for both manual-paste and
  // ingestion-driven flows. For ingestion drafts these mirror IngestedMessage;
  // for manual-paste they are the only record.
  inboundChannel                String?
  inboundSender                 String?
  inboundSubject                String?
  inboundBody                   String?          @db.Text
  // Lineage: when a draft is regenerated we DISCARD the prior version and
  // create a new row pointing back via parentId so the audit and UI can
  // surface the prior attempt without clobbering history.
  parentId                      String?
  parent                        Draft?           @relation("DraftLineage", fields: [parentId], references: [id])
  children                      Draft[]          @relation("DraftLineage")
  createdAt                     DateTime         @default(now())
  sentMarkedAt                  DateTime?
  // PRD §9.1 — adherence is measured against what was actually sent, not
  // the system's draft. Captured at mark-sent: the user's final text and
  // (if a holding deadline applied) how late they sent relative to it.
  sentText                      String?          @db.Text
  sentResponseLatencyMin        Int?
  // Backlog item 1 — bypassed-send detection. When the channel ingest
  // observes an OUT message that matches an existing SENT draft (verbatim
  // body match), we link the OUT IngestedMessage here. When no match is
  // found, we synthesise a brand-new Draft in SENT status with
  // `synthesisedFromOutboundIngest = true` and link the same OUT message.
  // Either way every observed outbound corresponds to one Draft — that's
  // what makes the "every send is scored" invariant survive bypass.
  outboundIngestedMessageId     String?          @unique
  outboundIngestedMessage       IngestedMessage? @relation("DraftOutbound", fields: [outboundIngestedMessageId], references: [id])
  synthesisedFromOutboundIngest Boolean          @default(false)

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership      Membership              @relation(fields: [membershipId], references: [id])
  ingestedMessage IngestedMessage?        @relation(fields: [ingestedMessageId], references: [id])
  actions         Action[]
  adherence       CommunicationAdherence?

  @@index([tenantId, membershipId, status])
}

model Action {
  id             String    @id @default(cuid())
  tenantId       String
  membershipId   String
  draftId        String?
  title          String
  detail         String?   @db.Text
  type           String    @default("task") // task | calendar | followup | research
  dueAt          DateTime?
  status         String    @default("OPEN")
  externalSystem String?
  externalId     String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id])
  draft      Draft?     @relation(fields: [draftId], references: [id])

  @@index([tenantId, membershipId, status])
}

// ─── Audit ─────────────────────────────────────────────────────────────────

model AuditEvent {
  id                String         @id @default(cuid())
  tenantId          String
  seq               BigInt // tenant-scoped monotonic sequence
  eventType         AuditEventType
  actorMembershipId String?
  subjectType       String
  subjectId         String
  payload           Json
  prevHash          String
  hash              String
  createdAt         DateTime       @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  Membership? @relation("AuditActor", fields: [actorMembershipId], references: [id])

  @@unique([tenantId, seq])
  @@index([tenantId, eventType, createdAt])
}

// ─── Phase 2+ entities (minimal — schema present so migrations don't churn)

model Channel {
  id           String   @id @default(cuid())
  tenantId     String
  kind         String // M365 | GOOGLE | SLACK | SHAREPOINT | IMANAGE | TEAMS | ZOOM | WHATSAPP_BUSINESS
  scope        Json?
  status       String   @default("INACTIVE")
  dpiaApproved Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auths    ChannelAuth[]
  messages IngestedMessage[]

  @@index([tenantId, kind])
}

model ChannelAuth {
  id              String    @id @default(cuid())
  tenantId        String
  channelId       String
  membershipId    String?
  encryptedTokens String    @db.Text
  scope           String?   @db.Text
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  channel    Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  membership Membership? @relation(fields: [membershipId], references: [id])

  @@index([tenantId, channelId])
}

model IngestedMessage {
  id          String    @id @default(cuid())
  tenantId    String
  channelId   String?
  externalId  String?
  threadId    String?
  direction   String // IN | OUT
  sender      String?
  recipients  Json?
  subject     String?
  body        String    @db.Text
  sentAt      DateTime?
  hash        String?
  redactFlags Json?
  createdAt   DateTime  @default(now())

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel       Channel?               @relation(fields: [channelId], references: [id])
  drafts        Draft[]
  outboundDraft Draft?                 @relation("DraftOutbound")
  sentiments    SentimentSignal[]
  opportunities OpportunityCandidate[]

  @@index([tenantId, threadId])
}

/// Meetings + paper drafting (PRD §7.4). Each meeting has a single
/// paper-author (default = creator; FCG may override per service line). The
/// system drafts agenda + discussion paper grounded in the description and
/// any prior IngestedMessages from the same participants. Lead time is
/// configurable on the FCG; meetings scheduled inside the lead window are
/// flagged short-notice but the paper is still drafted as soon as the user
/// asks.
model Meeting {
  id                      String             @id @default(cuid())
  tenantId                String
  externalId              String?
  title                   String
  description             String?            @db.Text
  location                String?
  startsAt                DateTime
  durationMin             Int                @default(60)
  createdByMembershipId   String?
  paperAuthorMembershipId String?
  /// PRD §7.5 — the meeting Chair approves Minutes before circulation.
  /// Defaults to the paper-author at creation time; an FCT/admin can reassign
  /// on the detail page (e.g. for committee meetings where the Chair is
  /// distinct from whoever drafted the agenda).
  chairMembershipId       String?
  transcriptOptIns        Json?
  /// Working days of lead time the FCG demanded for paper issuance at the
  /// time of creation. Snapshotted so the short-notice flag remains stable
  /// even if the FCG changes later.
  leadTimeWorkingDays     Int                @default(3)
  shortNotice             Boolean            @default(false)
  paperStatus             MeetingPaperStatus @default(NONE)
  agenda                  Json? // [{ item, durationMin?, owner? }]
  paperBody               String?            @db.Text
  openQuestions           Json? // string[]
  paperGeneratedAt        DateTime?
  paperIssuedAt           DateTime?
  paperFcgVersionUsed     Int?
  paperModelRunId         String?
  /// PRD §7.5 note-taking lifecycle. `noteTakingDisclosedAt` records when the
  /// pre-meeting disclosure was sent. `noteTakingBlocked` is set true (with a
  /// reason) once any participant opts out — transcript ingestion and
  /// summary/minutes generation refuse to run while blocked. Manually
  /// clearing the block requires audited override (out of scope for v1).
  noteTakingDisclosedAt   DateTime?
  noteTakingBlocked       Boolean            @default(false)
  noteTakingBlockReason   String?            @db.Text
  /// PRD §7.5 — the transcript ingested from the meeting platform (Teams,
  /// Zoom, Meet) or pasted manually as a fallback. The body is the raw text;
  /// agents read this directly. Stored on the Meeting row because each
  /// meeting has at most one canonical transcript — re-uploading replaces.
  transcriptBody          String?            @db.Text
  transcriptSource        TranscriptSource?
  transcriptIngestedAt    DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    Membership?          @relation("MeetingCreator", fields: [createdByMembershipId], references: [id])
  paperAuthor  Membership?          @relation(fields: [paperAuthorMembershipId], references: [id])
  chair        Membership?          @relation("MeetingChair", fields: [chairMembershipId], references: [id])
  participants MeetingParticipant[]
  records      MeetingRecord[]

  @@index([tenantId, startsAt])
  @@index([tenantId, paperStatus])
}

/// Per-meeting participant. Light-weight: name + email is enough to draft a
/// paper. `isMeetingCreator` is the signal we use to default paper-authorship.
/// Calendar OAuth ingestion (Phase 3) will populate this from the source
/// system; until then participants are entered manually. Not joined to a
/// Tenant relation: the row is scoped via Meeting.tenantId and `tenantId` is
/// kept as a denormalised field for index/query efficiency.
model MeetingParticipant {
  id                     String    @id @default(cuid())
  tenantId               String
  meetingId              String
  membershipId           String?
  name                   String
  email                  String?
  isExternal             Boolean   @default(false)
  isMeetingCreator       Boolean   @default(false)
  /// PRD §7.5 — external participants must be presented with an opt-out
  /// before joining. If any participant opts out, transcript ingestion is
  /// disabled for the whole meeting (see `Meeting.noteTakingBlocked`).
  /// `noteTakingOptedOut` is the per-participant flag; `optedOutAt` is the
  /// timestamp; `optOutReason` is optional free text from the participant.
  noteTakingOptedOut     Boolean   @default(false)
  noteTakingOptedOutAt   DateTime?
  noteTakingOptOutReason String?   @db.Text
  createdAt              DateTime  @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([tenantId, meetingId])
}

/// Post-meeting Summary / Formal Minutes (PRD §7.5). One row per (Meeting,
/// kind). Drafted from `Meeting.transcriptBody` once it has been ingested
/// AND `noteTakingBlocked` is false. The Chair (or paper-author by default)
/// approves before circulation.
///
/// Body is plain markdown. `agenda`/`actions` etc. live in the body — we
/// don't model them as separate columns because the Chair's edit pass is
/// the legal record and they edit prose, not structured fields. Audit events
/// for the lifecycle are MEETING_SUMMARY_DRAFTED/APPROVED and
/// MEETING_MINUTES_DRAFTED/APPROVED/CIRCULATED.
model MeetingRecord {
  id                       String              @id @default(cuid())
  tenantId                 String
  meetingId                String
  kind                     MeetingRecordKind
  status                   MeetingRecordStatus @default(DRAFTED)
  body                     String              @db.Text
  generatedAt              DateTime            @default(now())
  approvedAt               DateTime?
  approvedByMembershipId   String?
  circulatedAt             DateTime?
  circulatedByMembershipId String?
  fcgVersionUsed           Int?
  modelRunId               String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, kind])
  @@index([tenantId, meetingId])
  @@index([tenantId, status])
}

/// Sales Identifier candidate (PRD §8). Detected from inbound communications
/// — never autonomously routed externally. The Sales Reviewer designated by
/// the FCG for the (jurisdiction × serviceLine) classification accepts /
/// revises / rejects / routes-to-Partner. Default Partner is Acumon
/// Intelligence (PRD §8.3).
///
/// `signalQuotes` and `rationale` are evidence the model produced; we keep
/// them so the reviewer can sanity-check the classification before acting.
/// `decidedAt`/`decidedBy` capture the lifecycle terminator. Comments are a
/// separate model.
model OpportunityCandidate {
  id                      String    @id @default(cuid())
  tenantId                String
  /// The IngestedMessage that surfaced the candidate. Null only for
  /// manual-create entries (Phase 4: external feeds).
  sourceIngestedMessageId String?
  jurisdiction            String?
  serviceLine             String?
  /// new_engagement | expansion | renewal | cross_sell | referral
  classification          String?
  confidence              Float?
  rationale               String?   @db.Text
  signalQuotes            Json? // string[] of supporting quotes from the inbound
  suggestedReviewerTeam   String?
  /// NEW | UNDER_REVIEW | ACCEPTED | REVISED | REJECTED | ROUTED_TO_PARTNER
  status                  String    @default("NEW")
  reviewerMembershipId    String?
  /// DEFAULT (Acumon Intelligence) | CLIENT | THIRD_PARTY (PRD §8.3).
  partnerType             String    @default("DEFAULT")
  payload                 Json?
  modelRunId              String?
  decidedAt               DateTime?
  decidedByMembershipId   String?
  decisionReason          String?   @db.Text
  routeNotes              String?   @db.Text
  createdAt               DateTime  @default(now())

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceMessage IngestedMessage?     @relation(fields: [sourceIngestedMessageId], references: [id])
  reviewer      Membership?          @relation("OpportunityReviewer", fields: [reviewerMembershipId], references: [id])
  decidedBy     Membership?          @relation("OpportunityDecider", fields: [decidedByMembershipId], references: [id])
  comments      OpportunityComment[]

  @@index([tenantId, status])
  @@index([tenantId, reviewerMembershipId, status])
}

/// Free-form comment thread on a candidate (PRD §8.2). Reviewer notes flow
/// here before a decision is recorded; once the candidate is decided the
/// thread remains for audit and (under XCL opt-in, Phase 4) feeds the
/// curator pipeline.
model OpportunityComment {
  id                 String   @id @default(cuid())
  tenantId           String
  candidateId        String
  authorMembershipId String
  body               String   @db.Text
  createdAt          DateTime @default(now())

  candidate OpportunityCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  author    Membership           @relation("OpportunityCommentAuthor", fields: [authorMembershipId], references: [id])

  @@index([tenantId, candidateId])
}

/// Sentiment classification of a single inbound (PRD §9.3). Boundary detector
/// for counterparty dissatisfaction or unusual praise *with respect to firm
/// handling*. Most rows are NEUTRAL; only EXTREME_NEG against firm handling
/// triggers escalation routing to the assigned User and the FCT.
model SentimentSignal {
  id                     String    @id @default(cuid())
  tenantId               String
  ingestedMessageId      String?
  /// EXTREME_NEG | EXTREME_POS | NEUTRAL
  classification         String
  confidence             Float?
  /// Whether the signal is about the firm's handling of the matter (PRD §9.3).
  /// Counterparty unhappiness about their own outcomes is `false` and never
  /// escalates.
  isAboutFirmHandling    Boolean   @default(false)
  trigger                String?
  evidence               Json?
  shouldEscalate         Boolean   @default(false)
  /// Set when the signal is routed to the user/FCT inbox. Distinct from
  /// `shouldEscalate` (which is the model's recommendation) so we can audit
  /// the actual escalation event.
  escalatedAt            DateTime?
  acknowledgedAt         DateTime?
  acknowledgedById       String?
  /// Membership (draft owner) the escalation is routed to. The FCT also sees
  /// it via the firm-wide list.
  assignedToMembershipId String?
  modelRunId             String?
  createdAt              DateTime  @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingestedMessage IngestedMessage? @relation(fields: [ingestedMessageId], references: [id])
  assignedTo      Membership?      @relation("SentimentAssignee", fields: [assignedToMembershipId], references: [id])
  acknowledgedBy  Membership?      @relation("SentimentAcknowledger", fields: [acknowledgedById], references: [id])

  @@index([tenantId, classification, createdAt])
  @@index([tenantId, escalatedAt])
}

model AdherenceScore {
  id           String   @id @default(cuid())
  tenantId     String
  membershipId String
  period       String // YYYY-MM
  payload      Json // per-dimension scores
  overall      Float
  sampleN      Int
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id])

  @@unique([membershipId, period])
  @@index([tenantId, period])
}

/// Per-communication adherence score (PRD §9.1). One row per sent draft.
/// Aggregated up into AdherenceScore monthly for the FCT-facing dashboard.
model CommunicationAdherence {
  id               String    @id @default(cuid())
  tenantId         String
  draftId          String    @unique
  membershipId     String
  fcgVersionUsed   Int
  ucgVersionUsed   Int?
  overall          Float // 0..1
  perDimension     Json // { responseTime, tone, mandatoryPhrase, prohibitedPhrase, escalation } -> {score, verdict, evidence}
  perRule          Json // [{ ruleExternalId, source: "fcg"|"ucg", verdict, explanation }]
  modelRunId       String?
  createdAt        DateTime  @default(now())
  // Backlog item 1 — adherence escalation. When `overall` is below the
  // threshold the row is escalated to the assignee (= `membership`) AND
  // the FCT for governance, mirroring sentiment escalation.
  escalatedAt      DateTime?
  acknowledgedAt   DateTime?
  acknowledgedById String?

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  draft          Draft       @relation(fields: [draftId], references: [id], onDelete: Cascade)
  membership     Membership  @relation(fields: [membershipId], references: [id])
  acknowledgedBy Membership? @relation("AdherenceAcknowledger", fields: [acknowledgedById], references: [id])

  @@index([tenantId, membershipId, createdAt])
  @@index([tenantId, escalatedAt])
}

model DPIAAttestation {
  id           String    @id @default(cuid())
  tenantId     String
  version      Int
  scope        Json
  signedByName String
  signedByRole String
  signedAt     DateTime
  expiresAt    DateTime?
  documentRef  String?
  createdAt    DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model DSARequest {
  id           String    @id @default(cuid())
  tenantId     String
  subjectType  String // USER | COUNTERPARTY
  subjectIdent String
  kind         String // ACCESS | RECTIFY | ERASE | RESTRICT | PORT | OBJECT
  status       String    @default("OPEN")
  openedAt     DateTime  @default(now())
  dueAt        DateTime?
  fulfilledAt  DateTime?
  packageRef   String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model NoGoSubject {
  id        String   @id @default(cuid())
  tenantId  String
  label     String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, label])
}

model ModelRun {
  id                  String   @id @default(cuid())
  tenantId            String?
  purpose             String
  model               String
  inputHash           String?
  outputHash          String?
  latencyMs           Int?
  inputTokens         Int?
  outputTokens        Int?
  cacheReadTokens     Int?
  cacheCreationTokens Int?
  createdAt           DateTime @default(now())

  @@index([tenantId, purpose, createdAt])
}

/// Per-tenant per-month billing roll-up (PRD §15.1 + §15.2). One row per
/// tenant per calendar month. While the period is open (`status = DRAFT`)
/// the totals are recomputable from live data. When the Firm Administrator
/// (or the cron at month-end) closes the period, totals + plan snapshot are
/// frozen here for the invoice and a `BILLING_PERIOD_CLOSED` audit event is
/// written. Re-opening is an explicit, audited action.
model BillingPeriod {
  id                   String              @id @default(cuid())
  tenantId             String
  /// "YYYY-MM" — the calendar month the line items cover.
  period               String
  status               BillingPeriodStatus @default(DRAFT)
  closedAt             DateTime?
  closedByMembershipId String?
  currency             String              @default("GBP")
  /// Count of memberships that met the §15.2 "active" definition during the
  /// period. May exceed `billableUsers` if some active users were on a
  /// suspended membership at close time.
  activeUsers          Int                 @default(0)
  /// Memberships actually billed (active AND not suspended/anonymised AND
  /// not in revocation grace at the time of close).
  billableUsers        Int                 @default(0)
  /// Subset who additionally have the Sales Identifier add-on applied.
  salesIdUsers         Int                 @default(0)
  baseSubtotalMinor    Int                 @default(0)
  salesIdSubtotalMinor Int                 @default(0)
  cmkSubtotalMinor     Int                 @default(0)
  totalMinor           Int                 @default(0)
  /// Snapshot of the pricing plan + line-by-line breakdown at close time so
  /// invoices remain reproducible even if the tenant later changes plan.
  payload              Json
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshots BillingUserSnapshot[]

  @@unique([tenantId, period])
  @@index([tenantId, status])
}

/// Per-User-per-period snapshot. Captures the §15.2 active-vs-billable
/// determination so invoices are explainable: "this User was billed because
/// they had an authorised channel and produced 7 drafts in March".
///
/// `userEmail` is denormalised so the snapshot remains readable after a
/// Membership is anonymised.
model BillingUserSnapshot {
  id                     String           @id @default(cuid())
  tenantId               String
  periodId               String
  membershipId           String?
  userEmail              String
  role                   Role
  membershipStatus       MembershipStatus
  hasAuthorisedChannel   Boolean          @default(false)
  loggedInThisPeriod     Boolean          @default(false)
  hadDraftThisPeriod     Boolean          @default(false)
  draftCount             Int              @default(0)
  isActiveByPRD          Boolean          @default(false)
  isBillable             Boolean          @default(false)
  salesIdentifierApplies Boolean          @default(false)
  /// Short human-readable note on inclusion / exclusion ("billed", "no
  /// authorised channel", "suspended at close", "revocation grace", etc.).
  reason                 String           @default("")
  createdAt              DateTime         @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period     BillingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  membership Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([tenantId, periodId])
  @@index([periodId, isBillable])
}

// ─── Roadmap (PRD §16) ─────────────────────────────────────────────────────

/// Product roadmap. Global (no tenantId) — same five-phase plan shown to every
/// Client per PRD §15.3 switching/lock-in posture, so prospective and current
/// Clients can see when an asked-for feature is expected. Status transitions
/// (PLANNED → ACTIVE → COMPLETE) and exit-criterion ticks are mutated by an
/// Acumon operator (FIRM_ADMIN of the "acumon" tenant or ACUMON_ADMIN).
///
/// Audit events for roadmap mutations are written against the *operator's*
/// tenant (the audit chain is per-tenant). The roadmap rows themselves are
/// not under RLS.
model RoadmapPhase {
  id                String             @id @default(cuid())
  /// Stable short code from the PRD — P0, P1, P2, P3, P4. Used in URLs and audit payloads.
  code              String             @unique
  /// Sort order — kept explicit so an inserted "P1.5" stays in place.
  ordinal           Int
  name              String
  /// Window expressed in months from product start (PRD §16). End is inclusive.
  windowMonthsStart Int
  windowMonthsEnd   Int
  status            RoadmapPhaseStatus @default(PLANNED)
  /// Bullet list of in-scope items copied from the PRD column.
  scope             String[]
  /// Free-form operator notes — pinned commentary, links to release notes, etc.
  notes             String?            @db.Text
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  exitCriteria RoadmapExitCriterion[]

  @@index([ordinal])
}

/// One row per exit criterion within a phase. Operator can tick each off as it
/// is met (with timestamp + signer name) so the roadmap reflects real progress.
model RoadmapExitCriterion {
  id        String    @id @default(cuid())
  phaseId   String
  ordinal   Int
  text      String    @db.Text
  metAt     DateTime?
  metByName String?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  phase RoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId, ordinal])
}

// ─── Risks Register (PRD §17) ──────────────────────────────────────────────

/// Product-level risks register. Global (no tenantId) — these are the risks
/// Acumon faces in delivering the product, published to every Client per PRD
/// §15.3 transparency posture. Same shape as the §17 PRD table: title, severity,
/// list of mitigations, plus an operator-tracked status and last-reviewed
/// timestamp. Mutated by Acumon operators only (FIRM_ADMIN of the "acumon"
/// tenant or ACUMON_ADMIN); audit events are written against the operator's
/// own tenant chain. Not under RLS — see `prisma/rls.sql`.
model Risk {
  id             String       @id @default(cuid())
  /// Stable short code — R-01, R-02, … — used in URLs and audit payloads.
  code           String       @unique
  ordinal        Int
  title          String
  severity       RiskSeverity
  status         RiskStatus   @default(ACTIVE)
  /// Bullet list of mitigation controls, lifted from the PRD §17 column.
  mitigations    String[]
  /// Free-form operator commentary — links to incident write-ups, control owners, etc.
  notes          String?      @db.Text
  /// Last time an operator confirmed this risk is up-to-date (periodic review).
  reviewedAt     DateTime?
  reviewedByName String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([ordinal])
  @@index([severity, status])
}

/// Open Question for Sign-Off (PRD §18). Each tenant has its own copy of
/// the ten enumerated questions; the canonical text is seeded lazily on
/// first read (see `src/lib/signoff/index.ts`). Unlike the Roadmap (§16)
/// and Risks (§17) registers — which are §15.3 transparency surfaces and
/// therefore correctly modelled as global — these are each Client's own
/// governance answers (their retention period, their quorum default, their
/// pricing position). Two Clients on the same product instance must NOT
/// see each other's answers.
///
/// Tenant-scoped: under RLS via `prisma/rls.sql`. Audit events for
/// decisions are written into the same tenant's audit chain. The Acumon
/// vendor tenant is itself a Client of the product and uses this exactly
/// the same way; there is no privileged cross-tenant view.
model SignOffQuestion {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Stable short code Q-01, Q-02, … — unique per tenant, used in URLs and audit payloads.
  code          String
  ordinal       Int
  question      String        @db.Text
  /// PRD-side hint baked in (e.g. "default 30 days, anonymise or delete").
  /// Held separately from the question itself so a recorded decision can be
  /// shown alongside what the working assumption was when the question was raised.
  prdAssumption String?       @db.Text
  status        SignOffStatus @default(OPEN)
  /// Captured decision text — required when status moves to DECIDED.
  decision      String?       @db.Text
  decidedAt     DateTime?
  decidedByName String?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([ordinal])
  @@index([status])
}

// ─── Cross-Client Learning (PRD §11) ───────────────────────────────────────

/// PRD §11 Cross-Client Learning candidate. Source-tenant insights queued
/// for the Acumon Curator pipeline (PRD §11.3). Once Acumon takes a
/// candidate it acts as independent controller (PRD §11.2), so
/// XclCandidates are global (no tenantId; not under RLS). `sourceTenantId`
/// is provenance only — it is NOT a tenant-isolation key. Candidates only
/// enter the queue from a tenant that has opted in
/// (`Tenant.pricingCrossClientLearningOptIn = true`).
///
/// `originalText` is held inside Acumon's pipeline only (not exposed back
/// to other Clients); `redactedText` is what would be committed to global
/// defaults. The auto-redaction log lists every replacement so the human
/// curator can sanity-check the pipeline.
model XclCandidate {
  id                  String             @id @default(cuid())
  sourceTenantId      String
  /// Source subject for traceability (e.g. FCGProposal id, OpportunityCandidate id).
  sourceSubjectType   String
  sourceSubjectId     String
  kind                XclInsightKind
  status              XclCandidateStatus @default(PENDING)
  originalText        String             @db.Text
  redactedText        String             @db.Text
  /// Array of { kind, original, replacement } records — what the auto-pipeline stripped.
  redactionLog        Json
  /// Curator who reviewed (Acumon-tenant membership). Set on review.
  curatorMembershipId String?
  curatorTenantId     String?
  curatorDecidedAt    DateTime?
  curatorNotes        String?            @db.Text
  committedAt         DateTime?
  /// Set on COMMITTED — the operator who promoted the insight into defaults
  /// (may differ from the curator). Free-form name string for human display.
  committedByName     String?
  /// Per-Client decline log. Initially empty; populated when individual Clients
  /// decline a specific committed update (PRD §11.4 "Clients can review and
  /// decline specific updates"). Stored as a JSON array so the decline list
  /// doesn't pull a separate model into the schema for a v1 surface.
  declines            Json               @default("[]")
  modelRunId          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([sourceTenantId])
  @@index([kind, status])
}

/// PRD §11.3 quarterly re-identification testing log. An independent
/// reviewer attempts to re-identify the source tenant from a sample of
/// committed redacted insights. One row per quarter. `reidentifiedCount > 0`
/// is a finding that the redaction pipeline needs tightening.
model XclReidentificationTest {
  id                String   @id @default(cuid())
  /// "YYYY-Qn", e.g. "2026-Q2".
  quarter           String   @unique
  conductedAt       DateTime
  conductedByName   String
  externalReviewer  Boolean  @default(true)
  sampleSize        Int
  reidentifiedCount Int      @default(0)
  summary           String   @db.Text
  notes             String?  @db.Text
  createdAt         DateTime @default(now())

  @@index([conductedAt])
}

// ─── Tenant Termination Export (PRD §14.4) ────────────────────────────────

/// Snapshot of the export bundle generated for a terminating tenant
/// (PRD §14.4). Holds the JSON package alongside the timestamp and the
/// operator who generated it. The package format is documented per §15.3
/// (machine-readable JSON; CSV / PDF derivations rendered on demand from
/// this snapshot in v1).
///
/// One row per tenant per generation; the most recent is referenced from
/// `Tenant.terminationExportPackageId`. Older packages are retained for
/// the wind-down period and removed by the hard-delete sweep.
model TenantTerminationExport {
  id                      String   @id @default(cuid())
  tenantId                String
  generatedAt             DateTime @default(now())
  generatedByMembershipId String?
  generatedByName         String?
  /// JSON bundle: tenant settings, FCG versions + rules, UCG versions + rules,
  /// drafts (with their inbound snapshots), actions, meetings + records,
  /// channels, audit chain, DPIA attestations, DSAR records, billing periods,
  /// sign-off questions.
  payload                 Json
  /// Compact size in bytes for quick UI display + sanity check.
  bytes                   Int
  /// Tally captured at generation for the operator UI.
  counts                  Json

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, generatedAt])
}

// ─── Sub-Processor List (PRD §15.3) ───────────────────────────────────────

/// PRD §15.3 — Acumon publishes its sub-processor list in advance of
/// contracting. This is the canonical list, exposed read-only to every
/// Client and to prospective Clients. Same global-data pattern as Roadmap
/// (§16) and Risks (§17): no tenantId, NOT under RLS, mutations gated to
/// Acumon operators (FIRM_ADMIN of the "acumon" tenant or ACUMON_ADMIN).
/// Audit events are written against the operator's tenant chain.
model SubProcessor {
  id             String    @id @default(cuid())
  /// Stable code (e.g. "anthropic", "together") used in URLs and audit payloads.
  code           String    @unique
  ordinal        Int
  name           String
  /// Short role description (e.g. "LLM provider — primary", "Postgres host").
  role           String
  /// ISO country / region label (e.g. "US", "EU-IE", "UK"). Free-form text;
  /// not enumerated because the list will outgrow Jurisdiction.
  jurisdiction   String
  /// Categories of personal data this sub-processor processes.
  dataCategories String[]
  /// Operator-side reference to the contract (DPA / SCCs / sub-processor agreement).
  contractRef    String?
  notes          String?   @db.Text
  isActive       Boolean   @default(true)
  /// When the sub-processor was added to the production stack.
  addedAt        DateTime
  removedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  changes SubProcessorChange[]

  @@index([isActive, ordinal])
  @@index([ordinal])
}

/// Post-PRD hardening item 24 — sub-processor change notification with prior
/// notice. DPA art. 28(2)(a) obligates Acumon to give Clients advance notice
/// of additions or replacements of sub-processors so Clients can object and
/// (if unresolved) terminate. The existing `SubProcessor.isActive` toggle
/// flips silently and instantly; this model is the announcement layer.
///
/// Lifecycle:
///   ANNOUNCED → (after effectiveAt elapses) EFFECTIVE
///                 │
///                 └→ CANCELLED at any point before EFFECTIVE
///
/// On ANNOUNCED → EFFECTIVE: ADDED flips a freshly-staged SubProcessor row
/// from isActive=false to isActive=true; REMOVED flips an existing
/// SubProcessor row to isActive=false; MATERIAL_UPDATE leaves the row alone
/// (the change is documentary — contract terms, jurisdiction, data
/// categories — and is recorded by the operator updating the SubProcessor
/// row directly once the notice period has elapsed).
///
/// Global model — no tenantId. Audit events for announce/cancel/confirm
/// land on the Acumon operator's tenant chain (same pattern as Roadmap
/// §16, Risks §17, SubProcessor itself). Per-tenant objections live in
/// `SubProcessorObjection` (RLS-protected).
model SubProcessorChange {
  id              String                   @id @default(cuid())
  subProcessorId  String
  /// Operator-supplied free-text rationale visible to Clients in the
  /// notification + on the /switching page during the notice window.
  description     String                   @db.Text
  kind            SubProcessorChangeKind
  status          SubProcessorChangeStatus @default(ANNOUNCED)
  announcedAt     DateTime                 @default(now())
  /// Earliest moment the change can take effect. Default policy is +30 days
  /// from announcedAt per industry-standard DPA notice; operator can set it
  /// further out for low-risk material changes or up to 365 days. The
  /// lifecycle-sweep cron promotes ANNOUNCED → EFFECTIVE when now() crosses
  /// this timestamp.
  effectiveAt     DateTime
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelledReason String?                  @db.Text
  /// Membership that announced the change (FIRM_ADMIN or ACUMON_ADMIN of
  /// the Acumon tenant). Kept as a free-form string to avoid a cross-tenant
  /// FK; the membership id IS canonical.
  announcedById   String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  subProcessor SubProcessor            @relation(fields: [subProcessorId], references: [id], onDelete: Cascade)
  objections   SubProcessorObjection[]

  @@index([status, effectiveAt])
  @@index([subProcessorId, announcedAt])
}

enum SubProcessorChangeKind {
  /// Acumon is adding a new sub-processor. The SubProcessor row is created
  /// alongside the change with isActive=false, and is flipped to true on
  /// EFFECTIVE.
  ADDED
  /// Acumon is removing an existing sub-processor. The SubProcessor row
  /// stays isActive=true during the notice window, then flips on EFFECTIVE.
  REMOVED
  /// Documentary change to an existing sub-processor — jurisdiction shift,
  /// data-category expansion, new contract terms. The SubProcessor row is
  /// not touched by the lifecycle promotion; the operator updates the row
  /// directly once the notice window has elapsed.
  MATERIAL_UPDATE
}

enum SubProcessorChangeStatus {
  ANNOUNCED
  EFFECTIVE
  CANCELLED
}

/// Per-tenant audit-trail record of a Client raising an objection to a
/// `SubProcessorChange` during the notice window. Objections are visible to
/// the raising tenant + to Acumon operators reviewing the change, and are
/// captured on the tenant's audit chain. The objection is non-blocking by
/// design — under standard DPA terms, Acumon may proceed unless the parties
/// agree on remediation; either party may terminate if unresolved. This row
/// is the legal evidence that the objection was lodged.
///
/// Tenant-scoped + RLS-protected.
model SubProcessorObjection {
  id                   String    @id @default(cuid())
  tenantId             String
  subProcessorChangeId String
  /// Membership that raised the objection (FIRM_ADMIN of the Client).
  raisedById           String
  reason               String    @db.Text
  raisedAt             DateTime  @default(now())
  withdrawnAt          DateTime?
  withdrawnReason      String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  change SubProcessorChange @relation(fields: [subProcessorChangeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, subProcessorChangeId])
  @@index([subProcessorChangeId])
}

// ─── Onboarding Checklist (PRD §14.1) ─────────────────────────────────────

/// PRD §14.1 — per-tenant manual ticks for onboarding steps the platform
/// cannot itself observe (commercial signoff, SSO configuration, sub-
/// processor list acceptance, pilot conclusion, etc.). Steps the platform
/// CAN detect (DPIA attested, FCG committed, FCT quorum present, sandbox
/// provisioned) are computed at read time from existing data and do not
/// need a row here. The page combines both into the consolidated checklist.
///
/// Tenant-scoped + RLS-protected. The `code` is a stable identifier from
/// the canonical step list in `src/lib/onboarding/steps.ts`.
model OnboardingChecklistItem {
  id            String          @id @default(cuid())
  tenantId      String
  phase         OnboardingPhase
  /// Stable code from the canonical step list (e.g. "commercial.msa-signed",
  /// "technical.sso-configured", "configuration.fct-appointed").
  code          String
  checked       Boolean         @default(false)
  checkedAt     DateTime?
  checkedByName String?
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, phase])
}

// ─── Service Levels + Localisation + Accessibility (PRD §13) ──────────────

/// PRD §13.1 SLA target. Global catalogue — every Client sees the same
/// commitments. Acumon operators amend the catalogue (add a target,
/// tighten a threshold) and the operator console at `/sla` records
/// per-tenant per-month measurements against each.
///
/// Same global-data pattern as Roadmap, Risks, Sub-Processors, Integrations,
/// ProcessingActivity: no tenantId, NOT under RLS, mutations gated to
/// Acumon operators. Audit events on the operator's chain.
model SlaTarget {
  id          String   @id @default(cuid())
  /// Stable code (e.g. "availability-overall", "drafting-latency-short").
  code        String   @unique
  ordinal     Int
  name        String
  kind        SlaKind
  /// Numeric threshold. For AVAILABILITY this is a percentage (e.g. 99.9).
  /// For LATENCY this is the seconds limit (e.g. 5 for a ≤5s short-draft
  /// median). The display layer renders units from `kind`.
  threshold   Float
  /// Unit hint shown in the UI ("%" or "s" or "× audio duration").
  unit        String
  /// Aggregation rule for measurements: "median" | "p95" | "monthly_pct".
  aggregation String
  /// PRD scope ("business hours 07:00–19:00 local", "overall", "at UCG commit").
  scope       String
  /// Free-form operator commentary.
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  measurements SlaMeasurement[]

  @@index([ordinal])
  @@index([kind, isActive])
}

/// PRD §13.1 monthly measurement for a single tenant against a single
/// target. Tenant-scoped + RLS-protected so each Client only reads their
/// own performance numbers. Auto-computed for the latency-flavoured
/// targets from `ModelRun`; availability requires operator input from
/// external uptime monitoring.
model SlaMeasurement {
  id             String     @id @default(cuid())
  tenantId       String
  targetId       String
  /// "YYYY-MM"
  period         String
  /// The actual measured value, in the same unit as the target.
  observed       Float?
  outcome        SlaOutcome @default(INSUFFICIENT_DATA)
  /// Sample count behind the measurement (latency targets) or hours of
  /// observed coverage (availability targets).
  sampleN        Int        @default(0)
  /// JSON payload for additional dimensions: {p95, max, perDimension, ...}.
  payload        Json?
  /// Operator note (e.g. for a missed period, what mitigation was applied).
  note           String?    @db.Text
  recordedAt     DateTime   @default(now())
  recordedByName String?

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  target SlaTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([tenantId, targetId, period])
  @@index([tenantId, period])
  @@index([targetId, period])
  @@index([outcome])
}

/// PRD §13.5 Localisation. Global registry of supported languages. The
/// `isInterface` flag controls whether the language appears in the UI
/// language picker; `isDrafting` controls whether the drafting agent +
/// FCG/UCG content support that language. At GA the same set of 8
/// languages is supported for both per the PRD.
model SupportedLanguage {
  id          String   @id @default(cuid())
  /// BCP-47 code (e.g. "en-GB", "fr", "de").
  code        String   @unique
  /// English-language display name ("French (France)").
  name        String
  /// Endonym (the language's own name for itself, e.g. "Français").
  nativeName  String
  ordinal     Int
  isInterface Boolean  @default(true)
  isDrafting  Boolean  @default(true)
  /// Whether this language's typography needs RTL handling.
  rtl         Boolean  @default(false)
  /// Operator note (e.g. "GA at month 4", "EU expansion P3 milestone").
  notes       String?  @db.Text
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ordinal])
  @@index([isInterface, isDrafting])
}

/// PRD §13.4 Accessibility Statement. Single row for the active version;
/// older versions are retained (not soft-deleted) for the audit trail of
/// what the published commitment was on a given date. Mutations are
/// Acumon-operator-only; read is universal.
model AccessibilityStatement {
  id              String    @id @default(cuid())
  version         Int       @unique
  /// "WCAG 2.2 AA" target per PRD §13.4. Held as text so future versions
  /// (WCAG 3.0) don't need a schema change.
  conformanceTo   String
  /// Conformance claim — "Fully conformant", "Partially conformant", or
  /// "Not conformant". Held as text for the same reason as `conformanceTo`.
  claim           String
  body            String    @db.Text
  /// Last formal accessibility audit date.
  auditedAt       DateTime?
  auditedByName   String?
  /// Known issues with workarounds — JSON array of {issue, impact, workaround}.
  knownIssues     Json      @default("[]")
  isActive        Boolean   @default(false)
  publishedAt     DateTime?
  publishedByName String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
  @@index([version])
}

// ─── Breach Notification (PRD §12.9) ──────────────────────────────────────

/// PRD §12.9 — incident record on Acumon Intelligence's side. Acumon (as
/// processor) notifies affected Clients without undue delay and within 24
/// hours of becoming aware of a personal data breach; notifications carry
/// everything the Client needs to meet its 72-hour ICO/EDPB obligation.
///
/// Same global-data pattern as Roadmap, Risks, Sub-Processors, Integrations:
/// no tenantId, NOT under RLS. Mutations gated to Acumon operators (FIRM_ADMIN
/// of "acumon" or ACUMON_ADMIN). Audit events on operator's tenant chain
/// for incident lifecycle + on each affected tenant's chain for notifications.
model BreachIncident {
  id                  String         @id @default(cuid())
  /// Stable code in the form BR-YYYY-NNN — assigned at create time.
  code                String         @unique
  title               String
  /// Short factual description — what happened, what data was potentially
  /// exposed. Held in plain markdown.
  description         String         @db.Text
  /// When the incident is believed to have begun (best-known). May lag
  /// awareness by hours or days.
  detectedAt          DateTime?
  /// When Acumon became aware. The 24-hour client-notice clock starts here.
  awareAt             DateTime
  severity            BreachSeverity
  status              BreachStatus   @default(TRIAGE)
  /// Whether this is a personal-data breach in the meaning of UK GDPR
  /// Art. 4(12). Defaults true because the page only triggers when that
  /// classification is plausible; operator can flip if triage clears it.
  isPersonalData      Boolean        @default(true)
  /// Categories of data potentially affected (e.g. "drafts", "FCG content",
  /// "audit metadata"). Free-form strings.
  affectedCategories  String[]       @default([])
  /// Root-cause notes — added during INVESTIGATING.
  rootCause           String?        @db.Text
  /// Mitigations applied — added during CONTAINED + RESOLVED.
  mitigations         String[]       @default([])
  /// Total Clients with at least one notification linked to this incident.
  affectedClientCount Int            @default(0)
  containedAt         DateTime?
  resolvedAt          DateTime?
  recordedByName      String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  notifications BreachClientNotification[]

  @@index([status])
  @@index([awareAt])
  @@index([severity, status])
}

/// PRD §12.9 — per-affected-Client notification record. One row per
/// (incident, tenant) pair. `dueAt = incident.awareAt + 24h` so the SLA
/// breach is visible. Tenant-scoped + RLS-protected so each Client only
/// sees notifications addressed to them; the Acumon operator console reads
/// across via `superDb`.
model BreachClientNotification {
  id                 String                   @id @default(cuid())
  tenantId           String
  breachIncidentId   String
  status             BreachNotificationStatus @default(PENDING)
  dueAt              DateTime
  notifiedAt         DateTime?
  notifiedByName     String?
  notifiedToName     String?
  notifiedToRole     String?
  acknowledgedAt     DateTime?
  acknowledgedByName String?
  /// Snapshot of the dispatched notification body. Held in-platform so the
  /// audit trail does not depend on an external mail store.
  payload            String?                  @db.Text
  notes              String?                  @db.Text
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident BreachIncident @relation(fields: [breachIncidentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, breachIncidentId])
  @@index([tenantId, status])
  @@index([breachIncidentId])
  @@index([dueAt])
}

// ─── Cross-Border Transfer (PRD §12.6) ────────────────────────────────────

/// PRD §12.6 — per-tenant Transfer Impact Assessment. The system blocks
/// activation of any third-country sub-processor (i.e. one whose
/// jurisdiction is outside the tenant's UK/EU lock) until SCCs and a
/// documented TIA are in place for that tenant × sub-processor pair.
///
/// Tenant-scoped + RLS-protected like other Client governance data. The
/// global SubProcessor list (§15.3) is the catalogue; this table is the
/// per-Client authorisation layer. A sub-processor with a UK or EU
/// jurisdiction does not need a TIA — the activation gate only fires for
/// non-EU / non-UK rows.
model TransferImpactAssessment {
  id               String    @id @default(cuid())
  tenantId         String
  /// FK to SubProcessor.code — kept as a string FK because SubProcessor is
  /// a global table without RLS; relational join not enforced at the schema
  /// level (deletion of a sub-processor is rare and audited; we want the
  /// TIA history to survive even if the row is later marked inactive).
  subProcessorCode String
  status           TIAStatus @default(RECORDED)
  /// Documented SCC reference — typically the contract id / DocuSign
  /// envelope id of the signed Standard Contractual Clauses.
  sccDocumentRef   String
  /// Documented Transfer Impact Assessment reference — typically a link
  /// into the Client's compliance system.
  tiaDocumentRef   String
  /// Effective dates of the TIA. `effectiveTo` defaults to +12 months at
  /// recording; auto-flipped to EXPIRED by the §14.4 cron sweep when the
  /// date passes.
  effectiveFrom    DateTime
  effectiveTo      DateTime
  signedByName     String
  signedByRole     String
  /// Optional list of data categories covered by the TIA — strings lifted
  /// from the matching SubProcessor.dataCategories.
  dataCategories   String[]  @default([])
  notes            String?   @db.Text
  /// Set when the TIA is revoked (e.g. the Client closed the dependent
  /// channel) or expired without renewal.
  revokedAt        DateTime?
  revokedReason    String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, subProcessorCode, effectiveFrom])
  @@index([tenantId, status])
  @@index([tenantId, subProcessorCode])
  @@index([effectiveTo])
}

// ─── Controller / Processor Map (PRD §12.1) ───────────────────────────────

/// PRD §12.1 — published Controller / Processor matrix that every Client and
/// prospective Client can read. Rows match the PRD table: a labelled
/// processing activity, who the controller is, who the processor is, and
/// the contract / addendum that applies.
///
/// Same global-data pattern as Roadmap, Risks, Sub-Processors, Integrations:
/// no tenantId, NOT under RLS. Mutations gated to Acumon operators (FIRM_ADMIN
/// of "acumon" tenant or ACUMON_ADMIN). Audit events on the operator's chain.
///
/// Per-tenant applicability is computed at read time from tenant flags
/// (Sales Identifier on/off, XCL opt-in, voice authorised, partner type).
/// We do NOT store applicability per-tenant — the controller/processor model
/// is the same for every Client, only the activated subset varies.
model ProcessingActivity {
  id                String   @id @default(cuid())
  /// Stable code (e.g. "core", "xcl", "si-intra", "si-third-party", "auth", "voice").
  code              String   @unique
  ordinal           Int
  /// Display label, lifted from the PRD column.
  label             String
  /// Controller designation — free-form to match PRD ("Client", "Acumon
  /// Intelligence (independent controller)", "Client + third party (joint)").
  controller        String
  /// Processor designation — same pattern. May be "—" for activities where
  /// Acumon is itself the controller (e.g. XCL).
  processor         String
  /// Lawful basis classification (e.g. "legitimate interests", "consent",
  /// "contract", "legal obligation"). Free-form because some rows combine
  /// bases per A2 in PRD §1.2.
  lawfulBasis       String?
  /// Contract / addendum that governs the row. Free-form to match the PRD
  /// "Notes" column ("Standard DPA, EU/UK SCCs not required (in-region)",
  /// "Tripartite agreement", "Listed sub-processor", etc.).
  contract          String?
  /// Whether this activity processes personal data — almost all rows do, but
  /// future additions (e.g. anonymous analytics) may not.
  processesPersonal Boolean  @default(true)
  /// Whether this activity processes special-category data per UK GDPR Art. 9.
  processesSpecial  Boolean  @default(false)
  /// Per-tenant feature flag that activates this row. Read from the
  /// Tenant column at view time. Null means "always applies".
  ///   "always"                       — every Client (default)
  ///   "salesIdentifierEnabled"       — only when SI is on
  ///   "salesIdentifierThirdParty"    — only when SI Partner = third party
  ///   "crossClientLearningOptedIn"   — only when XCL is on
  ///   "voiceAuthorised"              — only when a Voice channel is active
  ///   "ssoConfigured"                — only when SAML/OIDC is active
  applicabilityFlag String?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ordinal])
}

// ─── Integration Tiers (PRD §10) ──────────────────────────────────────────

/// PRD §10 — every integration target Acumon offers (or plans to offer) as a
/// row. Global (no tenantId, NOT under RLS) — same global-data pattern as
/// Roadmap (§16), Risks (§17) and Sub-Processors (§15.3): mutations gated to
/// Acumon operators (FIRM_ADMIN of "acumon" tenant or ACUMON_ADMIN). Audit
/// events written against the operator's tenant chain.
///
/// Each target has a tier (PRD §10.1/10.2/10.3/SDK), a category that drives
/// `Channel.kind`, an auth mechanism, an array of OAuth scopes (or scope-like
/// permission strings), a status, and an optional `channelKind` mapping back
/// to the per-tenant `Channel` model. The `/integrations` page renders this
/// catalogue read-only to every tenant; each tenant's actually-authorised
/// surface is `/admin/channels`.
model IntegrationTarget {
  id             String              @id @default(cuid())
  /// Stable code (e.g. "m365", "google-workspace", "slack"). Used in URLs,
  /// audit payloads, and as the FK from `Channel.kind` for v1 targets.
  code           String              @unique
  ordinal        Int
  name           String
  vendor         String?
  tier           IntegrationTier
  category       IntegrationCategory
  status         IntegrationStatus   @default(PLANNED)
  /// Channel.kind value emitted when a tenant authorises this target
  /// (e.g. "M365", "GOOGLE", "SLACK"). Null for SDK / non-Channel targets
  /// (DocuSign event triggers, practice-management bridges).
  channelKind    String?
  /// OAuth + permission mechanism — "oauth2", "api_key", "saml", "webhook".
  /// Free-form because the integrations matrix is too varied for an enum.
  authMechanism  String              @default("oauth2")
  /// Array of scope strings the target requires. Documented per PRD §10.4
  /// "All integrations inherit the source system's permissions model".
  requiredScopes String[]            @default([])
  /// Surfaces this integration produces inside the platform — array of
  /// strings like "drafts", "minutes", "actions", "follow-ups". Drives the
  /// /integrations catalog without hard-coding per-target rendering.
  capabilities   String[]            @default([])
  /// Short human-readable role (e.g. "Email + calendar + chat", "Document
  /// management for legal").
  role           String?
  /// Operator commentary — limitations, prerequisite addenda, etc.
  notes          String?             @db.Text
  /// Lifecycle timestamps. `targetGaAt` is the date this target is committed
  /// to be GA; `availableSince` is when it actually shipped. These are
  /// independent because Tier 2 targets have a 6-month-from-GA SLO that
  /// outlives the parent product GA date.
  targetGaAt     DateTime?
  availableSince DateTime?
  deprecatedAt   DateTime?
  /// Whether this target hooks the §14.4 export schema directly, the §10.4
  /// SDK adaptor pattern, or neither — informational only.
  export         String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tier, ordinal])
  @@index([category, status])
  @@index([status])
}

// ─── Terms and Conditions persistence (PRD §15.4) ─────────────────────────

/// Per-tenant Client-Acumon terms record (PRD §15.4). Four kinds — MSA, DPA,
/// AUP, SLA — versioned independently. The Sub-Processor List is a global
/// surface under §15.3 and is intentionally NOT modelled here.
///
/// "Persistent until changed" + "survive non-renewal": records are tenant-
/// scoped + RLS-protected like other Client data, but excluded from the
/// §14.4 hard-deletion sweep — they remain readable for audit-log access,
/// DSAR fulfilment, and statutory retention per §12.5.
model TermsRecord {
  id                  String      @id @default(cuid())
  tenantId            String
  kind                TermsKind
  version             Int
  status              TermsStatus @default(DRAFT)
  /// Operator-side reference: signed-PDF storage path, DocuSign envelope id, contract repo link, etc.
  documentRef         String
  /// Full text or a summary of the operative terms — held in-platform so
  /// audit and DSAR responses do not depend on an external store.
  body                String      @db.Text
  effectiveFrom       DateTime?
  effectiveTo         DateTime?
  signedByName        String?
  signedByRole        String?
  signedAt            DateTime?
  countersignedByName String?
  countersignedAt     DateTime?
  notes               String?     @db.Text
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind, version])
  @@index([tenantId, kind, status])
  @@index([tenantId, status])
}

// ─── Notifications (post-PRD backlog item 6) ──────────────────────────────

/// Append-only log of every notification dispatch attempt. Idempotency is
/// enforced by the unique (membershipId, kind, dedupeKey) index — for the
/// weekly digest the dedupeKey is the ISO week ("2026-W19"), for immediate
/// triggers it's the source-row id (sentiment signal id, breach notification
/// id, adherence row id) so a flaky cron retry never sends the same email
/// twice.
///
/// Tenant-scoped + RLS-protected like other Client governance data. The row
/// is created whether or not the email actually went out — `status` records
/// the outcome (DISPATCHED / FAILED / SKIPPED_NO_EMAIL_SERVER) so an audit
/// can tell apart "no email server configured in this deploy" from "send
/// genuinely failed".
model NotificationDispatch {
  id           String   @id @default(cuid())
  tenantId     String
  membershipId String
  /// "weekly_digest" | "sentiment_escalation" | "breach_ack_required" | "adherence_escalation"
  kind         String
  dedupeKey    String
  subject      String
  channel      String   @default("email")
  /// "DISPATCHED" | "FAILED" | "SKIPPED_NO_EMAIL_SERVER"
  status       String
  errorMessage String?
  payload      Json
  sentAt       DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, kind, dedupeKey])
  @@index([tenantId, sentAt])
}

/// In-app inbox row generated alongside every immediate dispatch and every
/// weekly digest. Drives the "Notifications" tab + per-nav-item unread
/// badges. Tenant-scoped + RLS-protected. The same idempotency key as
/// `NotificationDispatch` is used so an event that fires twice in a single
/// run produces exactly one inbox row.
model NotificationInbox {
  id           String    @id @default(cuid())
  tenantId     String
  membershipId String
  kind         String
  dedupeKey    String
  title        String
  summary      String?   @db.Text
  body         String?   @db.Text
  /// In-tenant route to open the source artefact ("/<slug>/sentiment", etc.).
  href         String?
  createdAt    DateTime  @default(now())
  /// Set when the User opens the notification (or marks all as read).
  readAt       DateTime?
  /// Mirror of `NotificationDispatch.sentAt` if the email side actually went
  /// out — a User can see whether the email reached them or only the in-app
  /// row is on file.
  emailSentAt  DateTime?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, kind, dedupeKey])
  @@index([tenantId, membershipId, readAt])
  @@index([tenantId, createdAt])
}

/// Post-PRD hardening — rate-limiting bucket for API abuse protection.
///
/// One row per (scope, identity) tuple — see `src/lib/ratelimit/index.ts` for
/// the key shape. Identities are typically:
///   - "ip:<addr>:<scope>"           — unauthenticated/public endpoints
///   - "membership:<id>:<scope>"     — authenticated per-User endpoints
///   - "tenant:<id>:<scope>"         — tenant-wide ceiling
///   - "auth:<email>:<scope>"        — sign-in / OTP-verify per email
///
/// Fixed-window counter: when (now - windowStart) >= windowSeconds, the
/// upsert resets the bucket to count=1; otherwise it increments. The whole
/// transition runs in a single atomic Postgres UPDATE so concurrent requests
/// can't both pass through under load. The row is intentionally GLOBAL (not
/// tenant-scoped, not in `tenant_tables`) — the most important limits gate
/// pre-tenant-resolution endpoints (sign-in, public /status, OAuth callback)
/// and there's no Membership/Tenant context yet to scope by.
///
/// Stale rows are reaped by the lifecycle-sweep cron — once a key has been
/// untouched for 7 days it's safe to delete; a fresh request just re-creates it.
model RateLimitBucket {
  id          String    @id @default(cuid())
  /// Composite namespace string. Format: "<identity-kind>:<identity>:<scope>".
  /// See `RateLimitScope` literals in `src/lib/ratelimit/index.ts`.
  key         String    @unique
  /// Start of the current fixed window. The next request whose `now` is
  /// `>= windowStart + windowSeconds` resets the bucket.
  windowStart DateTime
  /// Hits within the current window.
  count       Int
  /// Last time `RATE_LIMIT_EXCEEDED` was written for this key. Throttles
  /// audit-event spam — we record the first overflow per hour, not every
  /// individual rejected request.
  lastAuditAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([updatedAt])
}

// ─── Cron heartbeat monitoring (post-PRD hardening item 22) ────────────────

/// One row per registered platform cron. Upserted by `withCronHeartbeat` on
/// every run; read by `/admin/health` (Acumon-only) and by the periodic
/// `runHealthCheck()` worker that writes `CRON_STALLED` audit events on the
/// Acumon operator tenant chain when a cron's `lastSuccessAt` has drifted
/// past its expected interval.
///
/// Global (no tenantId) — cron schedules are platform-wide, not per-tenant.
/// Excluded from `prisma/rls.sql tenant_tables`.
model CronHeartbeat {
  cronName                String    @id
  /// Expected schedule interval in minutes; informs stall detection
  /// (`lastSuccessAt < now - 2 × interval` flags the cron as stalled).
  /// Hardcoded in `src/lib/cron-health/register.ts`; update there if the
  /// Railway cron schedule changes.
  expectedIntervalMinutes Int
  /// Set unconditionally at the start of every run (success or failure).
  lastRunAt               DateTime?
  /// Set on successful completion. The primary signal — `consecutiveFailures`
  /// resets to 0 alongside this stamp.
  lastSuccessAt           DateTime?
  /// Set when the wrapped fn throws. `lastErrorMessage` captures the first
  /// 500 chars of `err.message` for the operator dashboard.
  lastFailureAt           DateTime?
  lastErrorMessage        String?
  lastDurationMs          Int?
  consecutiveFailures     Int       @default(0)
  /// Dedupe stamp for `CRON_STALLED` audit + notification. Re-alert only
  /// after `expectedIntervalMinutes` has elapsed since the last alert, so
  /// an operator sees one alert per genuine stall window — not one every
  /// 15 minutes (the health-check cadence).
  stalledNotifiedAt       DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([lastSuccessAt])
}

// ─── Audit chain background verification (post-PRD hardening item 23) ─────

enum AuditChainVerificationStatus {
  RUNNING
  OK
  TAMPERED
  ERRORED
}

/// One row per (tenant, verification run). Written by the daily
/// `/api/cron/audit-verify` worker which calls `verifyAuditChain(tenantId)`
/// for every active tenant. On OK the row records timing + event count;
/// on TAMPERED the row records `failedAtSeq` + emits
/// `AUDIT_CHAIN_TAMPERED` audit on BOTH the affected tenant's chain AND
/// the Acumon operator chain (chain integrity is a controllership and
/// processor concern simultaneously) + dispatches immediate notifications
/// to the affected tenant's FIRM_ADMINs AND Acumon operators.
///
/// Tenant-scoped + RLS-protected — the verification log is sensitive
/// (tells an attacker which chains have been touched and when they were
/// last verified). Listed in `prisma/rls.sql tenant_tables`.
model AuditChainVerification {
  id           String                       @id @default(cuid())
  tenantId     String
  tenant       Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       AuditChainVerificationStatus
  startedAt    DateTime                     @default(now())
  finishedAt   DateTime?
  eventCount   Int                          @default(0)
  /// Seq of the first event whose hash didn't validate. Stable across
  /// reruns of the same tamper — part of the dedupe key.
  failedAtSeq  BigInt?
  tookMs       Int?
  errorMessage String?
  /// Last time a tamper notification fired for THIS run. Subsequent runs
  /// that find the same failedAtSeq within the dedupe window are silent;
  /// a different failedAtSeq re-alerts immediately.
  notifiedAt   DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  @@index([tenantId, startedAt(sort: Desc)])
  @@index([status])
}

// ─── Auto-draft sweep observability (post-PRD hardening item 52) ──────────

enum AutoDraftSweepSource {
  CRON
  BACKFILL
}

/// One pass of the auto-draft sweep against one tenant. Persisted so the
/// operator can answer "is the engine producing drafts I expect, and if
/// not, why?" without trawling cron heartbeats.
///
/// Items 50 (the cron) and 51 (the operator backfill) both call
/// `runAutoDraftSweep`; the sweep writes one row per tenant per pass with
/// the effective window, the per-tenant cap, the counts, and a
/// histogram of skip reason codes from `produceDraftFromInbound`. The
/// row is the operator-facing complement to the per-draft `DRAFT_PRODUCED`
/// audit events and the per-press `AUTO_DRAFT_BACKFILL_TRIGGERED` event.
///
/// Tenant-scoped + RLS-protected — same posture as
/// `AuditChainVerification`. Cron-triggered rows have `triggeredByMembershipId`
/// null; backfill-triggered rows record the operator who pressed the button.
///
/// Persistence failures must NOT poison the sweep: the cron's job is to
/// produce drafts, and an observability row is a nice-to-have on top.
/// The sweep catches and logs persistence errors rather than letting them
/// kill the pass.
model AutoDraftSweepRun {
  id                      String               @id @default(cuid())
  tenantId                String
  source                  AutoDraftSweepSource
  /// Operator who triggered a BACKFILL pass. Null for CRON.
  triggeredByMembershipId String?
  startedAt               DateTime             @default(now())
  windowHours             Int
  maxPerTenant            Int
  /// Inbound rows examined this pass (those scanned before any skip
  /// decision). Bounded by the page-size cap inside the sweep.
  candidates              Int                  @default(0)
  produced                Int                  @default(0)
  skipped                 Int                  @default(0)
  errored                 Int                  @default(0)
  /// `{ reasonCode: count }` histogram. Reason codes are stable slugs
  /// (e.g. `draft_already_exists`, `no_active_channel_auth`,
  /// `sender_is_owning_user`) emitted by `produceDraftFromInbound` and
  /// the sweep's own pre-skip path. New codes can be added without a
  /// migration — the UI renders unknown codes verbatim.
  skipReasons             Json                 @default("{}")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggeredBy Membership? @relation("AutoDraftSweepTriggeredBy", fields: [triggeredByMembershipId], references: [id])

  @@index([tenantId, startedAt(sort: Desc)])
  @@index([source])
}

// ─── Outbound webhook delivery (post-PRD hardening item 14) ───────────────

/// A tenant-registered webhook endpoint. The Firm Administrator subscribes
/// a URL to a set of audit-event types and receives a signed POST whenever
/// any matching event lands on the tenant's audit chain. Subscriptions are
/// tenant-scoped + RLS-protected.
///
/// `secret` is encrypted at rest (AES-256-GCM via `src/lib/channels/crypto.ts
/// encryptJson`) so a row-level DB leak doesn't directly hand over the HMAC
/// signing key. The plaintext is shown once on creation and never again.
///
/// `eventTypes` is an array of AuditEventType enum strings or the wildcard
/// `"*"` (subscribe to everything). The dispatch path checks membership with
/// a simple includes() so the cost stays O(subscriptions) per event.
///
/// `consecutiveFailures` is bumped on every delivery that ultimately reaches
/// the dead-letter state; the dispatcher disables a subscription once that
/// crosses `autoDisableThreshold` (default 25 — about a day of failed
/// deliveries at the default retry cadence). A FIRM_ADMIN can re-enable
/// after fixing the receiver.
model WebhookSubscription {
  id                    String    @id @default(cuid())
  tenantId              String
  /// Human-readable label shown in the admin UI. Not used for delivery.
  name                  String
  /// HTTPS URL of the receiver. Validated at the application layer; we
  /// refuse loopback addresses and the schemes other than https in prod.
  url                   String
  /// Encrypted HMAC-SHA256 signing secret. Plaintext is shown once on
  /// creation and never read again.
  secretEncrypted       String    @db.Text
  /// Post-PRD hardening item 46 — secret rotation with grace window.
  /// When set, the dispatcher signs payloads with BOTH `secretEncrypted`
  /// (primary) and this previous secret until `secretPrevRetiresAt`. The
  /// signature header carries two `v1=…` segments so receivers can verify
  /// against either while they migrate to the new secret. After the
  /// retire timestamp the dispatcher stops signing with the previous
  /// secret; the lifecycle-sweep cron clears the column lazily on read
  /// is unnecessary because deliver.ts already short-circuits on stale
  /// retire.
  secretEncryptedPrev   String?   @db.Text
  /// Wall-clock instant after which `secretEncryptedPrev` stops being
  /// included in the signature header. Clamped to [+1h, +7d] at write
  /// time by `rotateSubscriptionSecret`.
  secretPrevRetiresAt   DateTime?
  /// Either ["*"] for "every event type" or an explicit list of
  /// AuditEventType enum strings. Storage as TEXT[] rather than the enum
  /// because Postgres doesn't allow ALTER TYPE on a column type used in an
  /// array column without a rewrite, and the audit-event enum changes often.
  eventTypes            String[]  @default([])
  /// When `enabled = false`, dispatch enqueues no new deliveries to this
  /// subscription. Toggled by the Firm Administrator OR automatically by
  /// the dispatcher when `consecutiveFailures >= autoDisableThreshold`.
  enabled               Boolean   @default(true)
  /// Threshold over which the dispatcher auto-flips `enabled = false`.
  /// Defaults to 25 — about a day of failures at the default backoff.
  autoDisableThreshold  Int       @default(25)
  /// Count of consecutive deliveries that ended DEAD_LETTERED. Reset to 0
  /// on every successful delivery.
  consecutiveFailures   Int       @default(0)
  /// When a delivery last succeeded.
  lastDeliveredAt       DateTime?
  /// When a delivery last ended DEAD_LETTERED.
  lastFailureAt         DateTime?
  /// Last delivery's HTTP status, for at-a-glance UI.
  lastStatusCode        Int?
  createdByMembershipId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  Membership?       @relation("WebhookSubCreatedBy", fields: [createdByMembershipId], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId, enabled])
  @@index([tenantId, createdAt])
}

/// One enqueued delivery of one event to one subscription. PENDING rows are
/// picked up by the cron worker, retried with exponential backoff up to
/// `maxAttempts`, and end in DELIVERED or DEAD_LETTERED. The audit event
/// that triggered the delivery is referenced by `auditEventId` so a
/// receiver can request a replay against the same canonical payload.
///
/// Tenant-scoped + RLS-protected so a leaked admin token from tenant A
/// cannot read tenant B's delivery history.
model WebhookDelivery {
  id               String    @id @default(cuid())
  tenantId         String
  subscriptionId   String
  /// AuditEventType string (not the enum — see WebhookSubscription.eventTypes
  /// for the same rationale).
  eventType        String
  /// Reference back to the audit chain. Nullable so we can manually enqueue
  /// a delivery from an admin replay even if the audit event was archived.
  auditEventId     String?
  /// Canonical JSON payload sent (and to-be-resent on retry — never
  /// re-serialised) so retries are byte-stable for the receiver.
  payload          Json
  /// Number of times we have attempted POST. First attempt = 1.
  attempt          Int       @default(0)
  /// Hard cap on attempts before flipping to DEAD_LETTERED. Defaults to 5
  /// — at the default backoff (1m, 5m, 30m, 2h, 12h) that's ~15 hours of
  /// retries before we give up.
  maxAttempts      Int       @default(5)
  /// PENDING — waiting for the cron worker to pick up
  /// IN_FLIGHT — locked by the worker for the current attempt
  /// DELIVERED — receiver returned 2xx; terminal
  /// DEAD_LETTERED — exceeded maxAttempts or hit a permanent failure; terminal
  status           String    @default("PENDING")
  /// Earliest moment the next attempt should fire. Set to now() on enqueue;
  /// bumped by backoff on transient failures.
  scheduledFor     DateTime  @default(now())
  /// Last attempt's HTTP status code (null if no HTTP response — DNS, TLS,
  /// timeout, etc.).
  lastStatusCode   Int?
  /// First 1024 chars of the receiver's response body, for debugging.
  lastResponseBody String?   @db.Text
  /// Last network/HTTP error message, for debugging.
  lastError        String?   @db.Text
  /// Set when status flips to DELIVERED or DEAD_LETTERED.
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, subscriptionId, createdAt])
  @@index([status, scheduledFor])
}

/// Post-PRD hardening item 16 — programmatic API access. Tenant-scoped,
/// RLS-protected. Issued as `ack_<prefix>_<secret>` (32 chars after the
/// brand) where `prefix` is the lookup index and the remainder is hashed
/// at rest via HMAC-SHA256(prefix||"."||secret, ENCRYPTION_KEY). The
/// plaintext is shown to the creator exactly once and never read back —
/// same posture as `UserTotp.recoveryCodesHashed` and
/// `WebhookSubscription.secretEncrypted`.
///
/// Authentication shape: caller sends `Authorization: Bearer <key>` to
/// any `/api/v1/*` route. The auth middleware:
///   1. parses the brand and prefix from the header,
///   2. looks up the row by prefix (UNIQUE index),
///   3. timing-safe-compares the recomputed hash,
///   4. checks `revokedAt IS NULL` AND `expiresAt > now()`,
///   5. resolves the creator-Membership's role + intersects with `scopes`.
/// The intersection — not the underlying role — gates the request.
///
/// `lastUsedAt` is updated conditionally (only when older than 60s) so a
/// hot integrator polling once per second writes at most once per minute.
/// Same write-throttling pattern as `Session.lastSeenAt` (item 13).
model ApiKey {
  id                    String    @id @default(cuid())
  tenantId              String
  /// Human-readable label shown in the admin UI, e.g. "Datadog SIEM
  /// audit ingest". Not used for auth.
  name                  String
  /// First 12 chars of the issued key (e.g. "ack_jbswy3"). Plaintext +
  /// UNIQUE — the lookup column. Safe to log: it carries no entropy past
  /// the lookup itself; the secret half is what authenticates.
  prefix                String    @unique
  /// HMAC-SHA256(prefix || "." || secret, ENCRYPTION_KEY). Hex-encoded.
  /// Verifies the secret half without ever storing it.
  hash                  String
  /// Encryption-key version this hash was keyed under. Backwards-compat
  /// default "v1" matches the pre-rotation single-key posture. Set on
  /// creation to the active version from the registry; verification looks
  /// up this version so a rotated ENCRYPTION_KEY doesn't invalidate
  /// pre-rotation keys. See `src/lib/crypto/keys.ts`.
  keyVersion            String    @default("v1")
  /// Subset of canonical scope strings (see
  /// `src/lib/auth/api-keys/scopes.ts`). Empty array = no scopes (rejected
  /// at auth); `["*"]` = every scope the creator-Membership's role grants.
  /// Stored as TEXT[] (not enum) so the canonical scope list can evolve
  /// without an enum migration.
  scopes                String[]  @default([])
  /// Hard expiry. Null = never expires. Always still revocable manually.
  expiresAt             DateTime?
  /// When the key last authenticated successfully. Throttled to >=60s
  /// between writes to keep traffic bounded.
  lastUsedAt            DateTime?
  /// Last IP that authenticated with this key (best-effort, behind a
  /// proxy). For incident response — distinguishing the SIEM's IP from
  /// an unexpected source. Same masking applied as Session.ipAddress on
  /// display.
  lastUsedIp            String?
  /// Revocation bookkeeping. Row is preserved for forensic history.
  revokedAt             DateTime?
  revokedById           String?
  revokedReason         String?
  /// The Membership that created the key. Authorisation derives from
  /// this Membership's role; auto-revoke fires when this Membership
  /// transitions to an inactive status.
  createdByMembershipId String
  createdAt             DateTime  @default(now())

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy Membership  @relation("ApiKeyCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: Cascade)
  revokedBy Membership? @relation("ApiKeyRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  idempotencyKeys ApiIdempotencyKey[]

  @@index([tenantId, revokedAt])
  @@index([createdByMembershipId])
  @@index([expiresAt])
}

/// Stripe-style idempotency keys for `/api/v1/*` write endpoints.
///
/// Lifecycle:
///   1. Pre-insert a RESERVATION row (`completedAt` null, `statusCode` null).
///   2. Run the handler.
///   3. UPDATE the row with the actual response + `completedAt = now()`.
///
/// A retried request that lands on the same `(apiKeyId, key, methodPath)`
/// returns the cached response without re-executing. A retry with the
/// same key but a different `requestHash` is a 422 conflict (Stripe
/// convention). A retry that lands on a still-reserved row gets a 409
/// "request still in progress" — concurrent same-key requests must
/// serialise, not double-execute.
///
/// Tenant-scoped: RLS in `prisma/rls.sql` blocks cross-tenant reads.
/// TTL: 24h, purged by lifecycle-sweep.
model ApiIdempotencyKey {
  id           String    @id @default(cuid())
  tenantId     String
  apiKeyId     String
  /// The Idempotency-Key header value the integrator supplied. Length
  /// bounded at the application layer (1..200 chars).
  key          String
  /// HTTP method + path the key was used against, e.g.
  /// `POST /api/v1/webhooks/replay`. Same key against different paths
  /// is treated as independent — keys are scoped per (method, path).
  methodPath   String
  /// SHA-256 hex of the request body. Empty-body requests hash an
  /// empty string. Used to detect "same key, different body" reuse
  /// (Stripe-style 422 conflict).
  requestHash  String
  /// HTTP status code of the cached response. Null while reserved.
  statusCode   Int?
  /// Cached response body. Null while reserved. Capped at 64KB at
  /// write time — larger responses skip caching (the request still
  /// succeeds, but a subsequent retry will re-execute).
  responseBody String?   @db.Text
  createdAt    DateTime  @default(now())
  /// Set on phase-3 promotion. Null = still reserved (in-flight).
  completedAt  DateTime?
  /// TTL boundary. After this, the row is purged by lifecycle-sweep
  /// and subsequent retries get fresh execution.
  expiresAt    DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, key, methodPath])
  @@index([tenantId])
  @@index([expiresAt])
}

/// Post-PRD hardening item 45 — per-Membership opt-out of opt-outable
/// notification email kinds. Tenant-scoped + RLS-protected.
///
/// Default behaviour (no row) = opted-in. The dispatcher only consults
/// this table when the kind is in `OPT_OUTABLE_KINDS`
/// (`src/lib/notifications/preferences.ts`); mandatory kinds
/// (breach_ack_required, audit_chain_tampered, subprocessor_*,
/// cron_stalled, sentiment_escalation, adherence_escalation,
/// totp_reset_by_admin) short-circuit the lookup and always send. So a
/// row with `emailEnabled=false` for a mandatory kind (e.g. inserted
/// directly into the DB) is silently ignored — defence in depth on top
/// of the `ValidationError` thrown by `setEmailEnabled` at the API edge.
///
/// The in-app inbox is unaffected; muting only suppresses the SMTP
/// send. The dispatch row records `status='SKIPPED_USER_PREFERENCE'`
/// so an operator can see why an email didn't go out.
model MembershipNotificationPreference {
  id           String   @id @default(cuid())
  tenantId     String
  membershipId String
  /// String mirroring `NotificationKind` in
  /// `src/lib/notifications/dispatch.ts`. Free-form text rather than an
  /// enum so adding a new kind doesn't require a migration (the
  /// `isOptOutable` allowlist in code is the gate).
  kind         String
  emailEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, kind])
  @@index([tenantId, membershipId])
}
