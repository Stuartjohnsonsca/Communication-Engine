// Acumon Communications — Prisma schema
// Phase 1 entities have full field detail; Phase 2+ entities have minimal fields
// so future migrations don't churn the schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Jurisdiction {
  UK
  EU_IE
  EU_DE
  EU_FR
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SANDBOX
  SUSPENDED
  /// PRD §14.4 — termination has been noticed but the wind-down window is
  /// still open. The tenant remains operational so the Client can pull their
  /// export package; hard-deletion runs after `terminationEffectiveAt` (90d
  /// default). The notice can be reversed during this window.
  TERMINATING
  TERMINATED
}

enum Role {
  FIRM_ADMIN
  FCT_MEMBER
  USER
  SALES_REVIEWER
  CURATOR
  ACUMON_ADMIN
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LEAVER_FROZEN
  ANONYMISED
}

enum FCGStatus {
  DRAFT
  PROPOSED
  COMMITTED
  SUPERSEDED
}

enum FCGCategory {
  TONE
  RESPONSE_TIME
  SALUTATION
  SIGNOFF
  SIGNATURE
  MANDATORY_PHRASE
  PROHIBITED_PHRASE
  ESCALATION
  REGULATORY
  LANGUAGE
}

enum CommChannel {
  EMAIL
  SLACK
  TEAMS
  LETTER
  REPORT
  WHATSAPP_BUSINESS
  ANY
}

enum ProposalState {
  DRAFTING
  OPEN_FOR_VOTE
  PASSED
  FAILED
  EXPIRED
  WITHDRAWN
}

enum VoteDecision {
  APPROVE
  REJECT
  ABSTAIN
}

enum UCGStatus {
  DRAFT
  JUDGED_PASS
  JUDGED_FAIL
  COMMITTED
  CONFLICTED
  SUPERSEDED
  FROZEN
  ANONYMISED
}

enum Verdict {
