  FAIL
  NOT_APPLICABLE
}

enum DraftKind {
  EMAIL
  HOLDING
  TECHNICAL
  ACTION_ONLY
}

enum DraftStatus {
  PROPOSED
  EDITED
  ACCEPTED
  DISCARDED
  SENT
