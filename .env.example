# Postgres (Railway provides DATABASE_URL automatically when you attach the Postgres plugin)
DATABASE_URL="postgresql://user:pass@localhost:5432/communication_engine?schema=public"
# DIRECT_URL is used by `prisma migrate` when DATABASE_URL goes through a connection pooler.
# On Railway with the managed Postgres plugin, set both to the same value.
DIRECT_URL="postgresql://user:pass@localhost:5432/communication_engine?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# LLM providers — at least one is required.
# - Anthropic Claude (best quality; used by default for the Compliance Judge and statutory Verifier).
# - Together AI (cheaper Llama 3.3/4 inference; used by default for FCG/UCG chat, drafting, sentiment).
# - If neither is set, the app falls back to a Mock provider that returns canned responses
#   so the rest of the platform (auth, voting, audit, UI) still works.
ANTHROPIC_API_KEY=""
TOGETHER_API_KEY=""
# TODO: pin to in-region (UK/EU) endpoint per PRD §12.6 before prod traffic.
ANTHROPIC_REGION="eu"

# Per-role overrides (format: provider:model). Optional; defaults are in src/lib/ai/models.ts.
# LLM_DEFAULT="together:meta-llama/Llama-3.3-70B-Instruct-Turbo"
# LLM_FCG_CHAT="anthropic:claude-sonnet-4-6"
# LLM_UCG_CHAT="together:meta-llama/Llama-3.3-70B-Instruct-Turbo"
# LLM_JUDGE="anthropic:claude-sonnet-4-6"
# LLM_DRAFT="together:meta-llama/Llama-3.3-70B-Instruct-Turbo"
# LLM_VERIFIER="anthropic:claude-haiku-4-5-20251001"
# LLM_SENTIMENT="together:meta-llama/Llama-3.3-70B-Instruct-Turbo"
# LLM_ADHERENCE="together:meta-llama/Llama-3.3-70B-Instruct-Turbo"
# LLM_OPPORTUNITY="together:meta-llama/Llama-3.3-70B-Instruct-Turbo"

# Magic-link email — two transports supported (item 111).
#
# Transport A: Microsoft Graph (recommended for M365-shop tenants
# where Security Defaults / Conditional Access blocks SMTP AUTH).
# Set ALL FOUR of these and the engine sends via Graph
# /users/{from}/sendMail using the OAuth client-credentials flow.
# One-time setup: create an app registration in Microsoft Entra
# with Application permission Mail.Send, grant admin consent,
# generate a client secret.
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
GRAPH_FROM=""  # mailbox to send from, e.g. noreply@acumon.com
#
# Transport B: SMTP via nodemailer (Resend, Postmark, SendGrid,
# raw SMTP). Used when GRAPH_* is unset.
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="no-reply@example.com"

# AES-GCM key for encrypting ChannelAuth.encryptedTokens (32 bytes, base64)
ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Seeds the audit hash chain (any non-empty string; rotating it breaks chain verification)
AUDIT_HASH_SEED="acumon-genesis-2026"

NODE_ENV="development"
